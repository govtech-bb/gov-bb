            "validations": {
              "required": {
                "error": "You must confirm the declaration to submit your request",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application Submitted",
      "elements": [],
      "behaviours": []
    }
