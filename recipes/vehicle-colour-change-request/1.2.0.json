            "fieldId": "proof-of-ownership",
            "validations": {
              "required": {
                "error": "Please upload proof of ownership",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "hint": "Upload a clear, recent photo of your vehicle showing its current colour",
            "label": "Current Photo of Vehicle",
            "fieldId": "photo-of-vehicle",
            "validations": {
              "required": {
                "error": "Please upload a current photo of your vehicle",
                "value": true
              }
            }
          }
        }
