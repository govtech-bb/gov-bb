{
  "name": "@govtech-bb/modular-forms-monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "lint:deps": "sherif -i express -i @types/express -i eslint -i @eslint/js -i react-markdown -r root-package-dependencies",
    "test:all": "nx run-many -t test",
    "dev:forms": "nx dev forms",
    "dev:api": "ln -sfn ../dist/apps/api/src node_modules/@ && nx dev api",
    "dev:landing": "nx dev landing",
    "dev:feature_flagging_ui": "nx dev feature-flagging-app",
    "start:forms": "nx start forms",
    "start:api": "ln -sfn ../dist/apps/api/src node_modules/@ && nx start api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:architecture-diagram": "tsx scripts/generate-architecture-diagram.ts",
    "generate:form-categories": "tsx scripts/generate-form-categories.ts",
    "generate:services-index": "tsx scripts/generate-services-index.ts",
    "generate:service-status-seed": "tsx scripts/generate-service-status-seed.ts",
    "seed:service-status": "tsx scripts/seed-service-status-from-content.ts",
    "validate-recipes": "tsx scripts/validate-recipes.ts",
    "dump-recipes": "tsx --env-file-if-exists=.env packages/database/scripts/dump-recipes-to-files.ts",
    "migration:create": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:create",
    "migration:create:help": "node -e \"console.log('Usage: pnpm migration:create -- <path/to/migrations>/<migration-name>'); console.log('Example: pnpm migration:create -- apps/api/src/database/migrations/AddFormSubmissionIndexes'); console.log('This creates an empty migration file; use migration:generate for diff-based migrations.');\"",
    "migration:generate": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:generate -d apps/api/typeorm.config.ts",
    "migration:run": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:run -d apps/api/typeorm.config.ts",
    "migration:revert": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:revert -d apps/api/typeorm.config.ts",
    "migration:show": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:show -d apps/api/typeorm.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@govtech-bb/content": "workspace:*",
    "@govtech-bb/form-types": "workspace:*",
    "@govtech-bb/registry": "workspace:*",
    "@nx/eslint": "^22.7.2",
    "@nx/js": "^22.6.5",
    "@swc/core": "^1.15.41",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "nx": "^22.6.5",
    "pg": "^8.21.0",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "sherif": "^1.11.1",
    "tailwind-csstree": "^0.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typeorm": "^0.3.28",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1041.0",
    "@govtech-bb/design": "^1.0.0-alpha.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eventemitter2": "^6.4.9",
    "luxon": "^3.7.2"
  },
  "lint-staged": {
    "*.{json,ts}": "pnpm exec prettier --write"
  }
}
