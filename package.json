{
  "name": "@govtech-bb/modular-forms-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test:all": "nx run-many -t test",
    "dev:forms": "nx dev forms",
    "dev:api": "nx dev api",
    "dev:landing": "nx dev landing",
    "start:forms": "nx start forms",
    "start:api": "nx start api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate-recipes": "tsx scripts/validate-recipes.ts",
    "dump-recipes": "tsx --env-file-if-exists=.env packages/database/scripts/dump-recipes-to-files.ts",
    "migration:create": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:create",
    "migration:create:help": "node -e \"console.log('Usage: pnpm migration:create -- <path/to/migrations>/<migration-name>'); console.log('Example: pnpm migration:create -- apps/api/src/database/migrations/AddFormSubmissionIndexes'); console.log('This creates an empty migration file; use migration:generate for diff-based migrations.');\"",
    "migration:generate": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:generate -d apps/api/typeorm.config.ts",
    "migration:run": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:run -d apps/api/typeorm.config.ts",
    "migration:revert": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:revert -d apps/api/typeorm.config.ts",
    "migration:show": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:show -d apps/api/typeorm.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@nx/eslint": "^22.7.2",
    "@nx/jest": "^22.6.5",
    "@nx/js": "^22.6.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^16.4.0",
    "nx": "^22.6.5",
    "pg": "^8.16.3",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "@govtech-bb/form-types": "workspace:*",
    "ts-jest-mock-import-meta": "^1.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typeorm": "^0.3.26",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "overrides": {
      "@tanstack/react-start": "1.168.9",
      "@tanstack/react-start-server": "1.167.6",
      "@tanstack/react-start-client": "1.168.1",
      "@tanstack/react-start-rsc": "0.1.9",
      "@tanstack/start-server-core": "1.169.1",
      "@tanstack/start-client-core": "1.170.1",
      "@tanstack/start-storage-context": "1.167.6"
    }
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1041.0",
    "@govtech-bb/design": "^1.0.0-alpha.15",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eventemitter2": "^6.4.9",
    "luxon": "^3.7.2"
  },
  "lint-staged": {
    "*.{json,ts}": "npx prettier --write"
  }
}
