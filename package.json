{
  "name": "@govtech-bb/modular-forms-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "dev:web": "nx dev web",
    "dev:api": "nx dev api",
    "start:web": "nx start web",
    "start:api": "nx start api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migration:create": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:create",
    "migration:create:help": "node -e \"console.log('Usage: npm run migration:create -- <path/to/migrations>/<migration-name>'); console.log('Example: npm run migration:create -- apps/api/src/database/migrations/AddFormSubmissionIndexes'); console.log('This creates an empty migration file; use migration:generate for diff-based migrations.');\"",
    "migration:generate": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:generate -d apps/api/typeorm.config.ts",
    "migration:run": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:run -d apps/api/typeorm.config.ts",
    "migration:revert": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:revert -d apps/api/typeorm.config.ts",
    "migration:show": "TS_NODE_PROJECT=apps/api/tsconfig.json typeorm-ts-node-commonjs migration:show -d apps/api/typeorm.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@nx/jest": "^22.6.5",
    "@nx/js": "^22.6.5",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^20.4.0",
    "pg": "^8.16.3",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.26",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@govtech-bb/design": "^1.0.0-alpha.15",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eventemitter2": "^6.4.9",
    "luxon": "^3.7.2"
  },
  "lint-staged": {
    "*.{json,ts}": "prettier --write"
  }
}
