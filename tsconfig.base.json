{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@govtech-bb/admin-ui": ["packages/admin-ui/src/index.ts"],
      "@govtech-bb/analytics": ["packages/analytics/src/index.ts"],
      "@govtech-bb/content": ["packages/content/src/index.ts"],
      "@govtech-bb/content/categories": ["packages/content/src/categories.ts"],
      "@govtech-bb/content/form-categories": [
        "packages/content/src/form-categories.ts"
      ],
      "@govtech-bb/form-builder": ["packages/form-builder/src/index.ts"],
      "@govtech-bb/form-types": ["packages/form-types/src/index.ts"],
      "@govtech-bb/expressions": ["packages/expressions/src/index.ts"],
      "@govtech-bb/form-conditions": ["packages/form-conditions/src/index.ts"],
      "@govtech-bb/form-renderer": ["packages/form-renderer/src/index.ts"],
      "@govtech-bb/form-validation": ["packages/form-validation/src/index.ts"],
      "@govtech-bb/registry": ["packages/registry/src/index.ts"],
      "@govtech-bb/database": ["packages/database/src/index.ts"],
      "@govtech-bb/git-publish": ["packages/git-publish/src/index.ts"],
      "@forms/types": ["packages/form-renderer/src/types/index.ts"],
      "@forms/lib": ["apps/forms/src/lib/form-builder/index.ts"],
      "@forms/form-api": ["apps/forms/src/lib/api/forms.ts"],
      "@forms/components": ["apps/forms/src/components"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
