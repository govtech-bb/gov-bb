# Combined env file for the docker-compose stack.
#
# Copy this to `.env` and adjust if you need to. The defaults work
# for `docker compose up` on a clean machine — no edits required.
#
#   cp .env.example .env
#   docker compose up

# ---------- Postgres ----------
# These three are used to (a) initialise the postgres container and
# (b) configure the api's connection. They must match.
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modular_forms

# Host port to expose postgres on. Change if you already run a local
# postgres on 5432.
DB_PORT=5432

# Host the dump-recipes script connects to (host-side, not the compose
# network). Defaults to localhost for dev; set to the RDS endpoint when
# dumping from staging/prod.
DB_HOST=localhost

# Set to "true" when dump-recipes targets RDS (or any TLS-only Postgres).
# Leave unset for local dev.
# DATABASE_SSL=true

# Verbose SQL logging from the api. Useful for debugging migrations.
DB_LOGGING=false

# ---------- API ----------
API_PORT=3001
# Comma-separated list of origins the api will accept browser requests from.
# landing (3000) and web (4200) are the host-mapped ports the compose stack
# exposes.
CORS_ORIGIN=http://localhost:3000,http://localhost:4200

# Toggle the example FormDefinition seed on api boot. Set to false if you
# want a fully empty database.
SEED_ON_BOOT=true

# ---------- Email (local SES mock) ----------
# In the compose stack the api sends submission emails to aws-ses-v2-local
# instead of real AWS SES. No edits required — the defaults below are baked
# into docker-compose.yml. View captured mail at http://localhost:8005.
#
# Host port for the local SES web inbox (container always listens on 8005).
SES_LOCAL_PORT=8005
# The mock accepts any sender; this is just what mail appears "From".
SES_FROM_ADDRESS=noreply@gov.bb
# aws-ses-v2-local ignores credentials, but the SDK signer needs non-empty
# values. Real keys are only needed if you point the api at actual AWS SES.
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are defined under AWS below.

# ---------- Web ----------
# URL the web app's browser code uses to call the api. Stays as localhost
# because browsers run on the host machine, not inside the docker network.
VITE_API_URL=http://localhost:3001

# ---------- Chat (RAG assistant) ----------
# Host port for the chat app (container always listens on 3000 internally).
CHAT_PORT=3002

# Anthropic API key for the LLM turn. REQUIRED — chat will return 500s
# without it. Get one from https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Claude model. Defaults to Haiku 4.5 (fast + cheap). Switch to e.g.
# claude-sonnet-4-6 for higher-quality answers at higher cost/latency.
LLM_MODEL=claude-haiku-4-5

# AWS credentials for Bedrock Titan embeddings (used by /api/retrieve and the
# ingest CLI). REQUIRED — retrieval will fail without them. Use IAM keys with
# `bedrock:InvokeModel` for `amazon.titan-embed-text-v2:0` in your region.
# If you use SSO/short-lived creds, also set AWS_SESSION_TOKEN.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ca-central-1
# Optional override if Bedrock lives in a different region than the rest of
# your AWS resources. Falls back to AWS_REGION when blank.
BEDROCK_REGION=
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ---------- Form Builder ----------
# Host port for the form_builder app (container listens on 3000 internally).
# form_builder reads/writes the modular_forms database directly via the
# shared DB_* vars above, and uses ANTHROPIC_API_KEY + AWS_* (also above)
# for its AI-assisted authoring features.
FORM_BUILDER_PORT=3003

# Session signing secret. Required — server routes throw on missing. The
# compose default (`dev-only-do-not-use...`) lets the stack boot; replace
# with `openssl rand -base64 32` output for any non-throwaway use.
SESSION_SECRET=

# GitHub OAuth gates the /builder routes. Without these, the app boots and
# serves the login redirect, but the round-trip won't complete. Register
# the OAuth App at https://github.com/organizations/govtech-bb/settings/applications
# with callback URL: ${OAUTH_REDIRECT_BASE}/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3003
# Org owning the repo + hosting the access team, and the team slug (URL form,
# e.g. 'form-authors') whose members may log in. Empty TEAM_SLUG lets the app
# boot but the login round-trip throws until set.
GITHUB_ORG=govtech-bb
GITHUB_TEAM_SLUG=

# form_builder uses different env names than chat for the AI provider —
# AI_PROVIDER/AI_MODEL here, vs LLM_MODEL for chat. ANTHROPIC_API_KEY is
# shared between both.
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# ---------- EzPay (payments) ----------
# Defaults are safe for local dev — no real payment integration. Override
# only if you're testing the live EzPay flow.
EZPAY_BASE_URL=https://test.ezpay.gov.bb
EZPAY_DEPARTMENT_API_KEYS={}
EZPAY_WEBHOOK_VERIFY_SIGNATURE=false
EZPAY_WEBHOOK_SECRET=
