# ---------------------------------------------------------------------------
# Required everywhere
# ---------------------------------------------------------------------------

# Postgres connection string. RDS in prod, local docker postgres in dev.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/cms

# Used to sign JWTs and cookies. In production, generate a long random
# string — e.g. `openssl rand -hex 32`. Never reuse across environments.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# ---------------------------------------------------------------------------
# URLs / origins
# ---------------------------------------------------------------------------

# Landing site origin, used to build the Live Preview iframe URL and to
# allow cross-origin reads + CSRF tokens from the public site.
LANDING_URL=http://localhost:3000

# Public origin of the admin itself. Set this in production to the deployed
# hostname so CSRF protection accepts requests from the admin's own UI.
# PAYLOAD_PUBLIC_URL=https://cms.alpha.gov.bb

# ---------------------------------------------------------------------------
# Optional — used by `pnpm seed` to create an initial admin login
# ---------------------------------------------------------------------------
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Email (AWS SES via SMTP)
# ---------------------------------------------------------------------------
# Generate SMTP credentials in the SES console (SMTP Settings → Create SMTP
# credentials). These are NOT the same as IAM access keys. Leave all blank
# locally — Payload will log emails to the console instead of sending.
# SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SES_SMTP_PORT=587
# SES_SMTP_USER=
# SES_SMTP_PASS=
# SES_FROM_EMAIL=no-reply@alpha.gov.bb
# SES_FROM_NAME=gov.bb CMS
