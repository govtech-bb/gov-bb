        },
        {
          "fieldId": "nationality",
          "label": "Nationality",
          "htmlType": "select",
          "placeholder": "Select your nationality",
          "options": [
            {
              "label": "United Kingdom",
              "value": "uk"
            },
            {
              "label": "Ireland",
              "value": "ie"
            },
            {
              "label": "Barbados",
              "value": "bb"
            },
            {
              "label": "Canada",
              "value": "ca"
            },
            {
              "label": "Australia",
              "value": "au"
            },
            {
              "label": "Other",
              "value": "other"
            }
          ],
          "multiple": false,
          "validations": {
            "required": {
              "value": true,
              "error": "Nationality is required"
            }
          }
        },
        {
          "fieldId": "national-id",
          "label": "National ID Number (Optional)",
          "htmlType": "text",
          "placeholder": "Enter your national ID",
          "hint": "Required only for BB nationals",
          "behaviours": [
            {
              "type": "fieldConditionalOn",
              "targetFieldId": "nationality",
              "operator": "equal",
              "value": "bb"
