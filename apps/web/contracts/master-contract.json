              "error": "National ID must be at least 8 characters"
            },
            "maxLength": {
              "value": 20,
              "error": "National ID must not exceed 20 characters"
            }
          }
        },
        {
          "fieldId": "nino",
          "label": "National Insurance Number (Optional)",
          "htmlType": "text",
          "placeholder": "e.g. AB 12 34 56 C",
          "hint": "Format: 2 letters, 6 digits, 1 letter",
          "validations": {
            "pattern": {
              "value": "^[A-Z]{2}\\s?\\d{6}\\s?[A-Z]$",
              "error": "Please enter a valid National Insurance number"
            }
          }
