# chat environment (R1: grounded RAG Q&A). Copy to .env.local for local dev.
# Server-oapps/chat/.env.examplenly — nothing here is shipped to the browser. AWS credentials are
# NEVER baked into the build; they come from the SDK default chain at runtime.

# --- Retrieval service base URL (REQUIRED) -----------------------------------
# Usually <chat-origin>/api. The grounding stage can't run without it.
RAG_URL=http://localhost:3001/api

# --- Landing frontend origin -------------------------------------------------
# Landing site origin every "go home" affordance points at (header logo, footer
# Home/Terms, Close). Defaults to https://alpha.gov.bb (prod). Set explicitly in
# non-prod builds.
# Sandbox: https://landing.sandbox.alpha.gov.bb
# Local: http://localhost:3000
# LANDING_URL=https://landing.sandbox.alpha.gov.bb

# --- pgvector store (REQUIRED for retrieval + ingest) ------------------------
# Postgres + pgvector. Without it the chat still runs but every answer abstains
# (no corpus to ground against). CHAT_DATABASE_URL is accepted as an alias.
DATABASE_URL=postgres://user:pass@host:5432/chat
# RDS needs SSL; the pool drives it from the host/sslmode. Set true once the CA
# is trusted (defaults to accepting RDS's chain in sandbox).
# DB_SSL_REJECT_UNAUTHORIZED=false

# --- Bedrock (chat model, query rewrite, Titan embeddings) -------------------
# Region falls back to AWS_REGION then ca-central-1.
# BEDROCK_REGION=ca-central-1
# LLM_MODEL=claude-haiku-4-5
# REWRITE_MODEL=claude-haiku-4-5
# BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# Opt-in static-prompt caching (varies by model/region): set 1 to enable.
# BEDROCK_PROMPT_CACHE=

# --- feature flags --------------------------------------------------------
# All default OFF → strictly RAG Q&A (R1). Enable one at a time as R2 ships.
# Resolved in config/features.ts. Set 1 / true to enable.
# FEATURE_FORMS=        # in-chat form collection + approval-gated submit
# FEATURE_FEEDBACK=     # feedback capture
# FEATURE_OFFERS=       # proactive "fill this form?" offers after an answer
# Master kill-switch: forces ALL of the above off regardless of their flags —
# one-line rollback to strict RAG.
# RAG_ONLY=

# --- Hardening ---------------------------------------------------------------
# Wall-clock ceiling (ms) for one streaming turn. Default 60000.
# TURN_TIMEOUT_MS=60000
# Per-IP request cap for POST /api/chat, per 60s window. Default 20. Optional —
# defense-in-depth alongside the WAF; raise/lower to retune without a code change.
# CHAT_RATE_LIMIT=20

# --- AWS credentials (SDK default chain) -------------------------------------
# Prefer SSO via a profile so short-lived creds refresh automatically:
AWS_PROFILE=
AWS_REGION=
# ...or static keys (not recommended): AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY