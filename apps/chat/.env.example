# Forms API base URL — chat fetches form definitions and POSTs submissions here.
# Sandbox: https://forms-sandbox.alpha.gov.bb
# Local: http://localhost:3001 (when running apps/api)
FORM_API_URL=https://forms-sandbox.alpha.gov.bb

# Forms FRONTEND (not the API). Chat hands users a link here when a form is too
# complex to complete inline (file uploads, payment). Required in all environments.
# Sandbox: https://forms.sandbox.alpha.gov.bb
FORMS_URL=https://forms.sandbox.alpha.gov.bb

# Landing site origin every "go home" affordance points at (header logo, footer
# Home/Terms, Close). Defaults to https://alpha.gov.bb (prod). Set explicitly in
# non-prod builds.
# Sandbox: https://landing.sandbox.alpha.gov.bb
# Local: http://localhost:3000
# LANDING_URL=https://landing.sandbox.alpha.gov.bb
