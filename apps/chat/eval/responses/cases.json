{
  "note": "Behavioural eval set for chat. Categories: direct = one expected service (judged deterministically by citation slug or a named service in the reply); ambiguous / miss / refusal / feedback are judged by `claude -p`. dialect 'bajan' checks the same intent in Barbadian vernacular. `messages` (vs `message`) is a multi-turn script judged on the LAST reply. citationSlug '__reply-only__' never matches a URL, forcing the replyIncludes text check.",
  "cases": [
    {
      "id": "direct-birth-cert",
      "category": "direct",
      "dialect": "standard",
      "message": "I need a replacement copy of my birth certificate",
      "expect": {
        "citationSlug": "birth-certificate",
        "replyIncludes": ["birth certificate"]
      }
    },
    {
      "id": "direct-birth-cert-bajan",
      "category": "direct",
      "dialect": "bajan",
      "message": "I tryin to get a copy of my birth paper, wuh I gotta do?",
