# Form Builder API (Express)

# Server
PORT=3003
NODE_ENV=development
# Comma-separated list of allowed origins; defaults to "*" if unset.
CORS_ORIGIN=http://localhost:3000,http://localhost:4200

# Auth
# Required in production. In development, the middleware lets requests through
# when this is unset (dev passthrough). Set it to lock down /builder/* locally.
ADMIN_API_TOKEN=

# Upstream apps/api base URL. Used by GET /builder/forms/published to proxy
# the in-memory recipe index for the form_builder "Open" modal. Optional:
# defaults to https://forms.api.sandbox.alpha.gov.bb when unset, so the "Open"
# modal works without a local apps/api. Local dev: apps/api runs on
# http://localhost:3001 (see docker-compose.yml's `api` service).
API_BASE_URL=http://localhost:3001

# Database (Postgres) — shared with apps/api
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modular_forms
DB_SYNCHRONIZE=false
DB_LOGGING=false

# AI (AWS Bedrock)
# Bedrock model ID or inference profile ID. ca-central-1 does not support
# ON_DEMAND for haiku-4-5 — use an inference profile (e.g. global.* or us.*).
AI_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_REGION takes precedence over AWS_REGION. Defaults to ca-central-1.
BEDROCK_REGION=ca-central-1
# AWS credentials are resolved from the standard credential chain
# (env vars, ~/.aws/credentials, IAM role, etc.) — no explicit env vars
# are required here.
