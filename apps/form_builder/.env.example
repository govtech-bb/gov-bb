DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modular_forms
DB_SYNCHRONIZE=false
DB_LOGGING=false
NODE_ENV=development
PORT=3001

# AI form builder (used by /builder/ai)
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
# AWS_REGION=us-east-1   # only needed when AI_PROVIDER=bedrock

BUILDER_API_URL=http://localhost:3003
API_BASE_URL=http://localhost:3001

# Public origin of the forms app (apps/forms) where published forms are served.
# Used to build the "Preview form" links shown after publishing/saving a form.
# Read in the browser via import.meta.env (ADR 0005); same var the landing app
# uses (ADR 0004). No trailing slash. The forms app runs on :3000 in dev.
# REQUIRED in production — an unset value fails fast (#1366); defaults to
# http://localhost:3000 only in dev.
VITE_FORMS_URL=http://localhost:3000

# Recipe preview token appended to "Preview form" links as ?preview=<token>.
# The forms app forwards it to the API (X-Recipe-Preview header) so an author
# can view an unpublished DB draft. Read in the browser via import.meta.env
# (ADR 0005), so Vite BAKES this value into the builder's JS bundle — accepted
# here because the builder is gated behind GitHub OAuth. FAILS CLOSED (#1366):
# there is no "demo" fallback — when unset the token is empty and no preview
# matches. Only unlocks drafts end-to-end if the API's RECIPE_PREVIEW_TOKEN
# matches.
VITE_RECIPE_PREVIEW_TOKEN=demo

# --- GitHub OAuth (PR 4) ---
# Register the OAuth App at https://github.com/organizations/govtech-bb/settings/applications
# Callback URL on the App must be: ${OAUTH_REDIRECT_BASE}/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
SESSION_SECRET=
# Builder's public origin (no trailing slash). E.g. http://localhost:3000 in dev.
OAUTH_REDIRECT_BASE=http://localhost:3000
# Org that owns the repo AND hosts the access team.
GITHUB_ORG=govtech-bb
# Team slug (URL form, e.g. 'form-authors') whose members may access the builder.
GITHUB_TEAM_SLUG=
# Branch the Deploy flow opens its recipe PR against. The LIVE env var wins at
# runtime wherever the platform exposes it (docker, ECS, local node) — change it
# and restart to retarget, no rebuild. As a fallback for Amplify Compute (whose
# SSR Lambda doesn't receive runtime env vars) the value is also baked into the
# bundle at build time via vite.config.ts `define`; there, set it in the Amplify
# console and redeploy to change it. REQUIRED in production — when neither the
# runtime var nor the baked PUBLISH_BASE_BRANCH_DEFAULT is set, the build fails
# fast (#1366) instead of silently targeting 'dev'; defaults to 'dev' only in a
# dev build.
PUBLISH_BASE_BRANCH=dev

# Where the content CMS (/content) live preview points: the landing app's
# /preview-start-page route. Read in the browser via import.meta.env (ADR
# 0005), so Vite bakes it into the bundle at build time. REQUIRED in production
# — an unset value fails fast (#1366); defaults to
# http://localhost:4000/preview-start-page only in dev (run the landing app
# with `pnpm dev --port 4000`). Set per environment in the deploy console.
#   e.g. https://sandbox.alpha.gov.bb/preview-start-page
# VITE_LANDING_PREVIEW_URL=
