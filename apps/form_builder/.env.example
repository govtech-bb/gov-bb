DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modular_forms
DB_SYNCHRONIZE=false
DB_LOGGING=false
NODE_ENV=development
PORT=3001

# Session cookie encryption. Must be at least 32 chars. Rotate periodically.
SESSION_SECRET=change-me-to-a-long-random-string-32-chars-or-more

# GitHub App (user-to-server OAuth). Create the App in the govtech-bb org with
# `contents: write`, `pull_requests: write`, `metadata: read` permissions and
# set the OAuth callback URL to {BUILDER_BASE_URL}/auth/callback.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# The org whose teams gate publish access. Used to filter /user/teams.
GITHUB_ORG_LOGIN=govtech-bb

# Slug of the team whose members can hit the Publish button.
GITHUB_PUBLISH_TEAM_SLUG=

# Base URL the builder is reachable at (no trailing slash). Used to build the
# OAuth callback URL. Examples: http://localhost:3001, https://forms.example.gov.
BUILDER_BASE_URL=http://localhost:3001

# Target repo for publish-via-PR. Defaults to govtech-bb/gov-bb.
GITHUB_REPO_OWNER=govtech-bb
GITHUB_REPO_NAME=gov-bb
GITHUB_PR_BASE_BRANCH=dev
