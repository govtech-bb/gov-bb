DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modular_forms
DB_SYNCHRONIZE=false
DB_LOGGING=false
NODE_ENV=development
PORT=3001

# AI form builder (used by /builder/ai)
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
# AWS_REGION=us-east-1   # only needed when AI_PROVIDER=bedrock

# --- GitHub OAuth (PR 4) ---
# Register the OAuth App at https://github.com/organizations/govtech-bb/settings/applications
# Callback URL on the App must be: ${OAUTH_REDIRECT_BASE}/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
SESSION_SECRET=
# Builder's public origin (no trailing slash). E.g. http://localhost:3000 in dev.
OAUTH_REDIRECT_BASE=http://localhost:3000
