# --- service_status API (apps/api) ---
# Base URL of the NestJS forms API that serves /service_status, /services and
# /form-definitions. No trailing slash. Defaults to the sandbox forms API for
# local dev so the tool works without a local api running.
#
# There is no admin token: the API authenticates its admin routes by the user's
# forwarded GitHub token (see app/server/api-client.ts), so signing in is all
# that's needed.
FEATURE_FLAGGING_API_URL=https://forms.api.sandbox.alpha.gov.bb

# --- Public site origins the services table links out to ---
# Each service title in the table links to its public page (the landing content
# page, or the form for form-only services), opened in a new tab. These are the
# base origins for that link, baked into the bundle at build time (no trailing
# slash). Unset → defaults to the local docker-stack origins below, so a local
# run links to localhost. Deployed builds MUST set both to the environment's
# origins (e.g. LANDING_URL=https://landing.sandbox.alpha.gov.bb,
# FORMS_URL=https://forms.sandbox.alpha.gov.bb).
LANDING_URL=http://localhost:3000
FORMS_URL=http://localhost:4200

# --- GitHub OAuth (REQUIRED — sign-in is enforced in every environment) ---
# Register the OAuth App at
# https://github.com/organizations/govtech-bb/settings/applications
# Callback URL must be: ${OAUTH_REDIRECT_BASE}/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
SESSION_SECRET=
# This tool's public origin (no trailing slash). Local dev serves a fixed port
# 3005 (vite.config.ts) — register the OAuth callback as
# http://localhost:3005/auth/github/callback to match.
OAUTH_REDIRECT_BASE=http://localhost:3005

# Authorization gate — used ONLY by deployed (production) builds; local dev
# authorizes any authenticated GitHub user and ignores these.
# Org that owns the repo AND hosts the access team.
GITHUB_ORG=govtech-bb
# Team slug (URL form, e.g. 'form-authors') whose members may access the tool.
GITHUB_TEAM_SLUG=

# --- Secrets Manager (prod only) ---
# JSON secret { session_secret } — hydrated at request time.
# FEATURE_FLAGGING_TOKENS_SECRET_ARN=
# JSON secret { client_id, client_secret } for GitHub OAuth.
# FEATURE_FLAGGING_GITHUB_OAUTH_SECRET_ARN=
