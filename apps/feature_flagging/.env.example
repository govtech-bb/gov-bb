# --- service_status API (apps/api) ---
# Base URL of the NestJS forms API that serves /service_status and
# /form-definitions. No trailing slash. Defaults to the sandbox forms API for
# local dev so the tool works without a local api running.
FEATURE_FLAGGING_API_URL=https://forms.api.sandbox.alpha.gov.bb

# Admin bearer token for PUT /service_status and GET /service_status/audit.
# Must match SERVICE_STATUS_ADMIN_TOKEN set on the api service. Left blank in
# local dev, where the api's AdminTokenGuard passes through (ADR-0061). In prod
# it is fetched from Secrets Manager via FEATURE_FLAGGING_TOKENS_SECRET_ARN.
SERVICE_STATUS_ADMIN_TOKEN=

# --- GitHub OAuth ---
# Register the OAuth App at
# https://github.com/organizations/govtech-bb/settings/applications
# Callback URL must be: ${OAUTH_REDIRECT_BASE}/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
SESSION_SECRET=
# This tool's public origin (no trailing slash). E.g. http://localhost:3000 in dev.
OAUTH_REDIRECT_BASE=http://localhost:3000
# Org that owns the repo AND hosts the access team.
GITHUB_ORG=govtech-bb
# Team slug (URL form, e.g. 'form-authors') whose members may access the tool.
GITHUB_TEAM_SLUG=

# --- Secrets Manager (prod only) ---
# JSON secret { admin_token, session_secret } — hydrated at request time.
# FEATURE_FLAGGING_TOKENS_SECRET_ARN=
# JSON secret { client_id, client_secret } for GitHub OAuth.
# FEATURE_FLAGGING_GITHUB_OAUTH_SECRET_ARN=
