<html>
  <head>
    <meta charset='utf-8' />
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      "Helvetica Neue", Arial, sans-serif; line-height: 1.6; color: #333;
      margin: 0; padding: 0; } .container { max-width: 800px; margin: 0 auto;
      padding: 20px; } h1 { color: #003087; border-bottom: 3px solid #FFB71B;
      padding-bottom: 10px; margin-bottom: 20px; font-size: 28px; } h2 { color:
      #003087; font-size: 20px; margin-top: 30px; margin-bottom: 15px; } h3 {
      color: #003087; font-size: 18px; margin-top: 20px; margin-bottom: 10px; }
      table { width: 100%; border-collapse: collapse; margin-bottom: 20px; } td
      { padding: 5px 10px; } td:first-child { background-color: #f5f5f5;
      font-weight: bold; width: 40%; } .section { margin-top: 20px; } .footer {
      margin-top: 30px; padding-top: 20px; border-top: 1px solid #ccc; color:
      #666; font-size: 12px; text-align: left; } .submitted-info {
      margin-bottom: 20px; font-size: 16px; }
    </style>
  </head>
  <body>
    <div class='container'>
      <h1>New Birth Registration Submission</h1>

      <div class='submitted-info'>
        <strong>Submitted:</strong>
        {{processedAt}}
      </div>

      <section class='section'>
        <h2>Marriage Status</h2>
        <p><strong>{{#if marriageStatus}}{{#if
                (eq marriageStatus 'yes')
              }}Married{{else if (eq marriageStatus 'no')}}Not married{{else}}Not
                specified{{/if}}{{else}}Not specified{{/if}}</strong></p>
      </section>

      <!-- Mother's Details -->
      <section class='section'>
        <h3>Mother's Details</h3>
        <table>
          <tbody>
            {{#if mother.firstName}}
              <tr>
                <td>First name:</td>
                <td>{{mother.firstName}}</td>
              </tr>
            {{/if}}
            {{#if mother.middleName}}
              <tr>
                <td>Middle name(s):</td>
                <td>{{mother.middleName}}</td>
              </tr>
            {{/if}}
            {{#if mother.lastName}}
              <tr>
                <td>Last name:</td>
                <td>{{mother.lastName}}</td>
              </tr>
            {{/if}}
            {{#if mother.otherSurname}}
              <tr>
                <td>Previous last name:</td>
                <td>{{mother.otherSurname}}</td>
              </tr>
            {{/if}}
            {{#if mother.dateOfBirth}}
              <tr>
                <td>Date of birth:</td>
                <td>{{mother.dateOfBirth}}</td>
              </tr>
            {{/if}}
            {{#if mother.address}}
              <tr>
                <td>Address:</td>
                <td>{{mother.address}}</td>
              </tr>
            {{/if}}
            {{#if mother.nationalRegistrationNumber}}
              <tr>
                <td>National registration number:</td>
                <td>{{mother.nationalRegistrationNumber}}</td>
              </tr>
            {{/if}}
            {{#if mother.passportNumber}}
              <tr>
                <td>Passport number:</td>
                <td>{{mother.passportNumber}}</td>
              </tr>
            {{/if}}
            {{#if mother.passportPlaceOfIssue}}
              <tr>
                <td>Passport place of issue:</td>
                <td>{{mother.passportPlaceOfIssue}}</td>
              </tr>
            {{/if}}
            {{#if mother.occupation}}
              <tr>
                <td>Occupation:</td>
                <td>{{mother.occupation}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </section>

      <!-- Father's Details (if provided) -->
      {{#if father.firstName}}
        <section class='section'>
          <h3>Father's Details</h3>
          <table>
            <tbody>
              {{#if father.firstName}}
                <tr>
                  <td>First name:</td>
                  <td>{{father.firstName}}</td>
                </tr>
              {{/if}}
              {{#if father.middleName}}
                <tr>
                  <td>Middle name(s):</td>
                  <td>{{father.middleName}}</td>
                </tr>
              {{/if}}
              {{#if father.lastName}}
                <tr>
                  <td>Last name:</td>
                  <td>{{father.lastName}}</td>
                </tr>
              {{/if}}
              {{#if father.otherSurname}}
                <tr>
                  <td>Previous last name:</td>
                  <td>{{father.otherSurname}}</td>
                </tr>
              {{/if}}
              {{#if father.dateOfBirth}}
                <tr>
                  <td>Date of birth:</td>
                  <td>{{father.dateOfBirth}}</td>
                </tr>
              {{/if}}
              {{#if father.address}}
                <tr>
                  <td>Address:</td>
                  <td>{{father.address}}</td>
                </tr>
              {{/if}}
              {{#if father.nationalRegistrationNumber}}
                <tr>
                  <td>National registration number:</td>
                  <td>{{father.nationalRegistrationNumber}}</td>
                </tr>
              {{/if}}
              {{#if father.passportNumber}}
                <tr>
                  <td>Passport number:</td>
                  <td>{{father.passportNumber}}</td>
                </tr>
              {{/if}}
              {{#if father.passportPlaceOfIssue}}
                <tr>
                  <td>Passport place of issue:</td>
                  <td>{{father.passportPlaceOfIssue}}</td>
                </tr>
              {{/if}}
              {{#if father.occupation}}
                <tr>
                  <td>Occupation:</td>
                  <td>{{father.occupation}}</td>
                </tr>
              {{/if}}
            </tbody>
          </table>
        </section>
      {{/if}}

      <!-- Child's Details -->
      <section class='section'>
        <h3>Child's Details</h3>
        <table>
          <tbody>
            {{#if child.firstNames}}
              <tr>
                <td>First name:</td>
                <td>{{child.firstNames}}</td>
              </tr>
            {{/if}}
            {{#if child.middleNames}}
              <tr>
                <td>Middle name(s):</td>
                <td>{{child.middleNames}}</td>
              </tr>
            {{/if}}
            {{#if child.lastName}}
              <tr>
                <td>Last name:</td>
                <td>{{child.lastName}}</td>
              </tr>
            {{/if}}
            {{#if child.dateOfBirth}}
              <tr>
                <td>Date of birth:</td>
                <td>{{child.dateOfBirth}}</td>
              </tr>
            {{/if}}
            {{#if child.sexAtBirth}}
              <tr>
                <td>Sex at birth:</td>
                <td>{{child.sexAtBirth}}</td>
              </tr>
            {{/if}}
            {{#if child.parishOfBirth}}
              <tr>
                <td>Place of birth:</td>
                <td>{{child.parishOfBirth}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </section>

      <!-- Certificates Requested -->
      <section class='section'>
        <h3>Certificates Requested</h3>
        <table>
          <tbody>
            <tr>
              <td>Number of certificates:</td>
              <td>{{numberOfCertificates}}</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Contact Information -->
      <section class='section'>
        <h3>Contact Information</h3>
        <table>
          <tbody>
            {{#if email}}
              <tr>
                <td>Email address:</td>
                <td>{{email}}</td>
              </tr>
            {{/if}}
            {{#if phoneNumber}}
              <tr>
                <td>Phone number:</td>
                <td>{{phoneNumber}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </section>

      <hr style='margin: 30px 0; border-top: 1px solid #ccc;' />
      <div class='footer'>
        <p>Sent from Government of Barbados Birth Registration Service<br />
          This email contains sensitive personal information - handle with care</p>
      </div>
    </div>
  </body>
</html>