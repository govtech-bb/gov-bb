<html>
  <head>
    <meta charset='utf-8' />
    <style>
      body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding:
      20px; } .header { background-color: #0b0c0c; color: white; padding: 20px;
      text-align: center; margin-bottom: 30px; } .header h1 { margin: 0;
      font-size: 24px; font-weight: bold; } .content { background-color:
      #f8f8f8; padding: 25px; border-radius: 5px; margin-bottom: 20px; } .field
      { margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid
      #ddd; } .field:last-child { border-bottom: none; } .label { font-weight:
      bold; color: #0b0c0c; margin-bottom: 5px; display: block; } .value {
      color: #333; white-space: pre-wrap; word-wrap: break-word; } .footer {
      text-align: center; color: #666; font-size: 12px; margin-top: 30px;
      padding-top: 20px; border-top: 1px solid #ddd; } .meta-info {
      background-color: #e8f4f8; padding: 15px; border-left: 4px solid #005ea5;
      margin-bottom: 20px; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class='header'>
      <h1>📋 New Feedback Submission</h1>
    </div>

    <div class='meta-info'>
      <strong>Submission ID:</strong>
      {{submissionId}}<br />
      <strong>Form:</strong>
      alpha.gov.bb Feedback Form<br />
      <strong>Submitted:</strong>
      {{processedAt}}
    </div>

    <div class='content'>
      <div class='field'>
        <span class='label'>Why did you visit alpha.gov.bb?</span>
        <div class='value'>{{visitReason}}</div>
      </div>

      <div class='field'>
        <span class='label'>What went wrong?</span>
        <div class='value'>{{whatWentWrong}}</div>
      </div>

      {{#if referrer}}
        <div class='field'>
          <span class='label'>Referrer</span>
          <div class='value'>{{referrer}}</div>
        </div>
      {{/if}}
    </div>

    <div class='footer'>
      <p>This is an automated notification from the Forms Processor API.</p>
      <p>© 2025 alpha.gov.bb - All rights reserved</p>
    </div>
  </body>
</html>