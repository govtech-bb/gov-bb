<html>
  <head>
    <meta charset='utf-8' />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        line-height: 1.55;
        color: #1a202c;
        margin: 0;
        padding: 0;
        background-color: #ffffff;
      }
      .wrapper {
        max-width: 720px;
        margin: 0 auto;
        background: #ffffff;
      }
      .header {
        background-color: #ffc726;
        padding: 18px 40px;
      }
      .header-brand img {
        height: 28px;
        width: auto;
        margin-right: 10px;
        vertical-align: middle;
      }
      .header-brand span {
        font-size: 18px;
        font-weight: 700;
        color: #1a202c;
        vertical-align: middle;
      }
      .body {
        padding: 8px 40px 32px;
      }
      .title {
        font-size: 34px;
        font-weight: 800;
        color: #1a202c;
        margin: 28px 0 24px;
        line-height: 1.15;
      }
      .summary {
        background-color: #e9ecf3;
        padding: 6px 24px;
        margin: 0 0 28px;
      }
      .summary table {
        width: 100%;
        border-collapse: collapse;
      }
      .summary td {
        padding: 11px 0;
        font-size: 15px;
        vertical-align: top;
      }
      .summary .s-label {
        font-weight: 700;
        color: #1a202c;
        width: 42%;
        padding-right: 16px;
      }
      .intro {
        font-size: 15px;
        color: #1a202c;
        margin: 0 0 24px;
      }
      .section {
        margin-bottom: 32px;
      }
      .section-title {
        font-size: 22px;
        font-weight: 800;
        color: #1a202c;
        margin: 0 0 4px;
      }
      .section table {
        width: 100%;
        border-collapse: collapse;
      }
      .section td {
        padding: 10px 0;
        font-size: 15px;
        vertical-align: top;
        border-bottom: 1px solid #e2e8f0;
      }
      .section tr:last-child td {
        border-bottom: none;
      }
      .field-label {
        color: #1a202c;
        font-weight: 700;
        width: 42%;
        padding-right: 16px;
      }
      .field-value {
        color: #1a202c;
      }
      .payment {
        background-color: #a8e6cf;
        padding: 14px 24px;
        margin: 0 0 28px;
      }
      .payment p {
        font-size: 15px;
        color: #1a202c;
        margin: 4px 0;
      }
      .tracking {
        background-color: #e9ecf3;
        padding: 8px 24px;
        margin: 8px 0 0;
      }
      .tracking table {
        width: auto;
        border-collapse: collapse;
      }
      .tracking td {
        padding: 8px 0;
        font-size: 15px;
      }
      .tracking .t-label {
        font-weight: 700;
        color: #1a202c;
        padding-right: 16px;
      }
      .footer {
        background-color: #00267f;
        color: #ffffff;
        padding: 32px 40px;
      }
      .footer p {
        font-size: 14px;
        color: #ffffff;
        margin: 0 0 16px;
        max-width: 75%;
      }
      .footer .copyright {
        font-size: 14px;
        margin: 0;
        opacity: 0.9;
      }
      .footer-crest {
        float: right;
        height: 76px;
        width: auto;
        margin-left: 24px;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='header'>
        <div class='header-brand'>
          {{#if coatOfArmsUrl}}
            <img src='{{coatOfArmsUrl}}' alt='' />
          {{/if}}
          <span>Government of Barbados</span>
        </div>
      </div>

      <div class='body'>
        <h1 class='title'>You have received a request for {{formTitle}}</h1>

        <div class='summary'>
          <table>
            <tr>
              <td class='s-label'>Service:</td>
              <td>{{formTitle}}</td>
            </tr>
            <tr>
              <td class='s-label'>Submission ID:</td>
              <td>{{submissionId}}</td>
            </tr>
            <tr>
              <td class='s-label'>Submission date:</td>
              <td>{{submittedDate}}</td>
            </tr>
            <tr>
              <td class='s-label'>Submission time:</td>
              <td>{{submittedTime}}</td>
            </tr>
          </table>
        </div>

        {{#if payment}}
          <div class='payment'>
            <p><strong>Payment amount received:</strong> {{payment.amountReceived}}</p>
            <p><strong>EzPay transaction ID:</strong> {{payment.transactionId}}</p>
          </div>
        {{/if}}

        <p class='intro'>Here is the data from this request:</p>

        {{#each sections}}
          <div class='section'>
            <div class='section-title'>{{title}}</div>
            <table>
              {{#each fields}}
                <tr>
                  <td class='field-label'>{{label}}</td>
                  <td class='field-value'>{{value}}</td>
                </tr>
              {{/each}}
            </table>
          </div>
        {{/each}}

        {{#if fileLinks}}
          <div class='section'>
            <div class='section-title'>Uploaded Documents</div>
            <table>
              {{#each fileLinks}}
                <tr>
                  <td class='field-label'>{{name}}</td>
                  <td class='field-value'><a href='{{url}}'>Download</a></td>
                </tr>
              {{/each}}
            </table>
          </div>
        {{/if}}

        <div class='tracking'>
          <table>
            <tr>
              <td class='t-label'>Reference:</td>
              <td>{{submissionId}}</td>
            </tr>
          </table>
        </div>
      </div>

      <div class='footer'>
        {{#if coatOfArmsUrl}}
          <img class='footer-crest' src='{{coatOfArmsUrl}}' alt='' />
        {{/if}}
        <p>This is an automated confirmation email from the Government of Barbados.</p>
        <p>Please do not reply to this email.</p>
        <p class='copyright'>&copy; {{year}} Government of Barbados</p>
      </div>
    </div>
  </body>
</html>
