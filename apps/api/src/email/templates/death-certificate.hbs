<html>
  <head>
    <meta charset='utf-8' />
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      "Helvetica Neue", Arial, sans-serif; line-height: 1.6; color: #333;
      margin: 0; padding: 0; } .container { max-width: 800px; margin: 0 auto;
      padding: 20px; } h1 { color: #003087; border-bottom: 3px solid #FFB71B;
      padding-bottom: 10px; margin-bottom: 20px; font-size: 28px; } h2 { color:
      #003087; font-size: 20px; margin-top: 30px; margin-bottom: 15px; } h3 {
      color: #003087; font-size: 18px; margin-top: 20px; margin-bottom: 10px; }
      table { width: 100%; border-collapse: collapse; margin-bottom: 20px; } td
      { padding: 8px 12px; border-bottom: 1px solid #eee; } td:first-child {
      background-color: #f5f5f5; font-weight: bold; width: 40%; } .section {
      margin-top: 20px; } .footer { margin-top: 30px; padding-top: 20px;
      border-top: 1px solid #ccc; color: #666; font-size: 12px; text-align:
      left; } .submitted-info { margin-bottom: 20px; font-size: 16px;
      background-color: #f0f8ff; padding: 15px; border-left: 4px solid #003087;
      } .highlight { background-color: #fff3cd; padding: 10px; border: 1px solid
      #ffeaa7; border-radius: 4px; margin: 10px 0; }
    </style>
  </head>
  <body>
    <div class='container'>
      <h1>New Death Certificate Application</h1>

      <div class='submitted-info'>
        <strong>Application Submitted:</strong>
        {{processedAt}}<br />
        <strong>Relationship to Deceased:</strong>
        {{relationship}}
      </div>

      <!-- Applicant Details -->
      <section class='section'>
        <h2>Applicant Information</h2>
        <table>
          <tbody>
            {{#if applicant.title}}
              <tr>
                <td>Title:</td>
                <td>{{#if (eq applicant.title 'mr')}}Mr{{else if
                    (eq applicant.title 'ms')
                  }}Ms{{else if
                    (eq applicant.title 'mrs')
                  }}Mrs{{else}}{{applicant.title}}{{/if}}</td>
              </tr>
            {{/if}}
            {{#if applicant.firstName}}
              <tr>
                <td>First Name:</td>
                <td>{{applicant.firstName}}</td>
              </tr>
            {{/if}}
            {{#if applicant.middleName}}
              <tr>
                <td>Middle Name:</td>
                <td>{{applicant.middleName}}</td>
              </tr>
            {{/if}}
            {{#if applicant.lastName}}
              <tr>
                <td>Last Name:</td>
                <td>{{applicant.lastName}}</td>
              </tr>
            {{/if}}
            {{#if applicant.email}}
              <tr>
                <td>Email:</td>
                <td>{{applicant.email}}</td>
              </tr>
            {{/if}}
            {{#if applicant.telephoneNumber}}
              <tr>
                <td>Telephone Number:</td>
                <td>{{applicant.telephoneNumber}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>

        <h3>Address</h3>
        <table>
          <tbody>
            {{#if applicant.addressLine1}}
              <tr>
                <td>Address Line 1:</td>
                <td>{{applicant.addressLine1}}</td>
              </tr>
            {{/if}}
            {{#if applicant.addressLine2}}
              <tr>
                <td>Address Line 2:</td>
                <td>{{applicant.addressLine2}}</td>
              </tr>
            {{/if}}
            {{#if applicant.parish}}
              <tr>
                <td>Parish:</td>
                <td>{{applicant.parish}}</td>
              </tr>
            {{/if}}
            {{#if applicant.postalCode}}
              <tr>
                <td>Postal Code:</td>
                <td>{{applicant.postalCode}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>

        <h3>Identification</h3>
        <table>
          <tbody>
            {{#if applicant.idNumber}}
              <tr>
                <td>National ID Number:</td>
                <td>{{applicant.idNumber}}</td>
              </tr>
            {{/if}}
            {{#if applicant.passportNumber}}
              <tr>
                <td>Passport Number:</td>
                <td>{{applicant.passportNumber}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </section>

      <!-- Application Details -->
      <section class='section'>
        <h2>Application Details</h2>
        <table>
          <tbody>
            {{#if relationship}}
              <tr>
                <td>Relationship to Deceased:</td>
                <td>{{relationship}}</td>
              </tr>
            {{/if}}
            {{#if reasonForRequest}}
              <tr>
                <td>Reason for Request:</td>
                <td>{{reasonForRequest}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </section>

      <!-- Deceased Details -->
      <section class='section'>
        <h2>Deceased Information</h2>
        <table>
          <tbody>
            {{#if deceased.firstName}}
              <tr>
                <td>First Name:</td>
                <td>{{deceased.firstName}}</td>
              </tr>
            {{/if}}
            {{#if deceased.middleName}}
              <tr>
                <td>Middle Name:</td>
                <td>{{deceased.middleName}}</td>
              </tr>
            {{/if}}
            {{#if deceased.lastName}}
              <tr>
                <td>Last Name:</td>
                <td>{{deceased.lastName}}</td>
              </tr>
            {{/if}}
            {{#if deceased.idNumber}}
              <tr>
                <td>National ID Number:</td>
                <td>{{deceased.idNumber}}</td>
              </tr>
            {{/if}}
            {{#if deceased.knownDateOfDeath}}
              <tr>
                <td>Known Date of Death:</td>
                <td>{{#if
                    (eq deceased.knownDateOfDeath 'yes')
                  }}Yes{{else}}No{{/if}}</td>
              </tr>
            {{/if}}
            {{#if deceased.dateOfDeath}}
              <tr>
                <td>Date of Death:</td>
                <td>{{deceased.dateOfDeath}}</td>
              </tr>
            {{/if}}
            {{#if deceased.estimatedDateOfDeath}}
              <tr>
                <td>Estimated Date of Death:</td>
                <td>{{deceased.estimatedDateOfDeath}}</td>
              </tr>
            {{/if}}
            {{#if deceased.placeOfDeath}}
              <tr>
                <td>Place of Death:</td>
                <td>{{deceased.placeOfDeath}}</td>
              </tr>
            {{/if}}
            {{#if deceased.causeOfDeath}}
              <tr>
                <td>Cause of Death:</td>
                <td>{{deceased.causeOfDeath}}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </section>

      <!-- Order Details -->
      <section class='section'>
        <h2>Order Information</h2>
        <div class='highlight'>
          <strong>Number of Copies Requested:</strong>
          {{order.numberOfCopies}}
        </div>
      </section>

      <!-- Footer -->
      <div class='footer'>
        <p>
          This is an automated email from the Government of Barbados Forms
          Processing System.<br />
          Death Certificate applications are processed during regular business
          hours.<br />
          Please allow 5-10 business days for processing.<br /><br />

          <strong>Important:</strong>
          Additional documentation may be required for verification purposes.
        </p>
      </div>
    </div>
  </body>
</html>