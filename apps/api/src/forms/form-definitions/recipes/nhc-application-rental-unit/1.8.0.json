{
  "formId": "nhc-application-rental-unit",
  "title": "Application for Rental Unit/Lot",
  "description": "National Housing Corporation (NHC) application for rental unit or lot. Household income must be $3,000/month or less.",
  "version": "1.8.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your NHC Rental Application has been received",
        "recipientField": "applicant-contact.applicant-email"
      }
    }
  ],
