        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Marital status",
            "fieldId": "applicant-marital-status",
            "options": [
              {
                "label": "Single",
                "value": "single"
              },
              {
                "label": "Married",
                "value": "married"
              },
              {
                "label": "Widowed",
                "value": "widowed"
              },
              {
                "label": "Divorced",
                "value": "divorced"
              },
              {
                "label": "Separated",
                "value": "separated"
