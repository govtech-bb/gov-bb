{
  "formId": "jobstart-plus-programme",
  "title": "Apply to Job start Plus Programme",
  "description": "Apply to the Jobstart Plus Programme run by the Ministry of Labour, Social Security and Third Sector.",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your JobStart Plus application has been received",
        "recipientField": "contact-details.contact-email"
      }
    },
    {
      "type": "email",
      "config": {
        "recipientField": "config.mdaEmail"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "Tell us about yourself",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "applicant-title"
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "applicant-first-name",
            "validations": {
              "required": {
                "error": "First name is required",
                "value": true
              },
              "minLength": {
                "error": "First name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "hint": "Optional. Provide only if known",
            "fieldId": "applicant-middle-name"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "applicant-last-name",
            "validations": {
              "required": {
                "error": "Last name is required",
                "value": true
              },
              "minLength": {
                "error": "Last name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "hint": "For example, 30 12 1986",
            "fieldId": "applicant-dob",
            "validations": {
              "gt": {
                "error": "You must be at least 16 years old",
                "value": "16",
                "transform": "yearsSince"
              },
              "lt": {
                "error": "You must be no more than 34 years old",
                "value": "34",
                "transform": "yearsSince"
              },
              "required": {
                "error": "Date of birth is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/sex",
          "overrides": {
            "fieldId": "applicant-sex",
            "validations": {
              "required": {
                "error": "Sex is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-select",
          "overrides": {
            "ui": {
              "width": "medium"
            },
            "label": "Marital status",
            "fieldId": "marital-status",
            "options": [
              {
                "label": "Single",
                "value": "single"
              },
              {
                "label": "Married",
                "value": "married"
              },
              {
                "label": "Divorced",
                "value": "divorced"
              }
            ],
            "validations": {
              "required": {
                "error": "Marital Status is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "ui": {
              "width": "medium"
            },
            "label": "National Identification (ID) Number",
            "fieldId": "applicant-nid",
            "behaviours": [
              {
                "type": "optionalIf",
                "value": true,
                "operator": "equal",
                "targetStepId": "applicant-details",
                "targetFieldId": "passport-toggle"
              }
            ],
            "validations": {
              "required": {
                "error": "ID Number is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/show-hide",
          "overrides": {
            "hint": "If you don't have a National ID number, you can use your passport number instead.",
            "label": "Use passport number instead",
            "fieldId": "passport-toggle"
          }
        },
        {
          "ref": "components/passport-number",
          "overrides": {
            "ui": {
              "width": "long"
            },
            "label": "Passport Number",
            "fieldId": "applicant-passport-number",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": true,
                "operator": "equal",
                "targetStepId": "applicant-details",
                "targetFieldId": "passport-toggle"
              }
            ],
            "validations": {
              "required": {
                "error": "Passport number is required",
                "value": true
              },
              "minLength": {
                "error": "Passport number must be at least 6 characters",
                "value": 6
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Do you have a National Insurance number (NIS)?",
            "fieldId": "has-nis-number",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "NIS Number is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/national-insurance-number",
          "overrides": {
            "ui": {
              "width": "medium"
            },
            "label": "Provide your National Insurance number (NIS)",
            "fieldId": "nis-number",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetStepId": "applicant-details",
                "targetFieldId": "has-nis-number"
              }
            ],
            "validations": {
              "required": {
                "error": "NIS Number is required",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "disability-support",
      "title": "Do you have a disability?",
      "description": "We ask you this so we can accommodate accessibility or support needs.",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "ui": {
              "hideLabel": true
            },
            "hint": "If you are over 24, you must have a disability or long-term health condition to apply.",
            "label": "Do you have a disability or long-term health condition?",
            "fieldId": "has-disability",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Do you have a disability is required.",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "What is your disability or long-term health condition?",
            "fieldId": "disability-details",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetStepId": "disability-support",
                "targetFieldId": "has-disability"
              }
            ],
            "validations": {
              "required": {
                "value": true
              },
              "minLength": {
                "value": "5"
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "isDisabled": true,
            "validations": {
              "required": {
                "value": true,
                "error": "If you are over 24, you must have a disability or long-term health condition to apply."
              },
              "equal": {
                "error": "If you are over 24, you must have a disability or long-term health condition to apply."
              }
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetStepId": "applicant-details",
                "targetFieldId": "applicant-dob",
                "operator": "gte",
                "value": "25",
                "transform": "yearsSince"
              },
              {
                "type": "optionalIf",
                "targetStepId": "disability-support",
                "targetFieldId": "has-disability",
                "operator": "equal",
                "value": "yes"
              }
            ],
            "label": "Are you 25 years or older, without a disability?"
          }
        }
      ],
      "behaviours": []
    },
