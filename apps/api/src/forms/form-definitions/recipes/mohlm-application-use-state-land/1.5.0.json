{
  "formId": "mohlm-application-use-state-land",
  "title": "Application to Use State Land",
  "description": "Ministry of Housing, Lands and Maintenance application form for using state land",
  "version": "1.5.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your application to use state land has been received",
        "recipientField": "contact-information.email"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "Tell us about yourself",
      "elements": [
        {
          "ref": "components/title"
        },
        {
          "ref": "components/first-name"
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "hint": "Optional"
          }
        },
        {
          "ref": "components/last-name"
        },
        {
          "ref": "components/sex",
          "overrides": {
            "validations": {
              "required": {
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "label": "National Identification (ID) Number",
            "validations": {
              "required": {
                "value": true
              }
            },
            "ui": {
              "width": "medium"
            },
            "hint": "Enter your valid National ID Number (for example, 450702-0130)"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "label": "Address line 1",
            "fieldId": "applicant-address-line-1"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "ui": {
              "hideLabel": true
            },
            "label": "Address line 2",
            "fieldId": "applicant-address-line-2",
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "applicant-parish"
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "fieldId": "applicant-postcode",
            "hint": "Optional"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "applicant-type",
      "title": "Who is applying?",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Are you applying as an individual or organisation?",
            "fieldId": "applying-as",
            "options": [
              {
                "label": "Individual",
                "value": "individual"
              },
              {
                "label": "Business",
                "value": "business"
              },
              {
                "label": "Organisation",
                "value": "organisation"
              }
            ],
            "validations": {
              "required": {
                "error": "Select whether you are applying as an individual or organisation",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Business name",
            "fieldId": "business",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetFieldId": "applying-as",
                "operator": "equal",
                "value": "business"
              }
            ]
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Organisation name",
            "fieldId": "organisation-name",
            "validations": {
              "required": {
                "error": "Enter the organisation name",
                "value": true
              }
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetFieldId": "applying-as",
                "operator": "equal",
                "value": "organisation"
              }
            ]
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "contact-information",
      "title": "How do we contact you?",
      "elements": [
        {
          "ref": "components/email",
          "overrides": {
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/home-telephone",
          "overrides": {
            "hint": "Optional"
          }
        },
        {
          "ref": "components/work-telephone",
          "overrides": {
            "hint": "Optional"
          }
        },
        {
          "ref": "components/mobile-telephone",
          "overrides": {
            "validations": {
              "required": {
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "property-details",
      "title": "Give the property details of the land",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "label": "Address line 1",
            "fieldId": "property-address-line-1",
            "validations": {
              "required": {
                "error": "Enter the property address",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "ui": {
              "hideLabel": true
            },
            "label": "Address line 2",
            "fieldId": "property-address-line-2",
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "property-parish",
            "validations": {
              "required": {
                "error": "Select the parish",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "fieldId": "property-postcode",
            "hint": "Optional"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "hint": "Enter the GPS coordinates of the property if available",
            "label": "GPS coordinates",
            "fieldId": "gps-coordinates",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "proposed-use",
      "title": "Proposed use of the land",
      "elements": [
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "ui": {
              "width": "long"
            },
            "label": "What activities will be carried out on the land?",
            "fieldId": "activities-to-be-carried-out",
            "validations": {
              "required": {
                "error": "Describe the activities to be carried out",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "usage-period",
      "title": "Usage period",
      "elements": [
        {
          "ref": "components/generic-date",
          "overrides": {
            "label": "Start date",
            "fieldId": "start-date",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the start date of the usage period"
              },
              "futureOrToday": {
                "error": "Start date must be in the current year or later"
              }
            }
          }
        },
        {
          "ref": "components/generic-date",
          "overrides": {
            "label": "End date",
            "fieldId": "end-date",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the end date of the usage period"
              },
              "onOrAfter": {
                "targetStepId": "usage-period",
                "referenceFieldId": "start-date",
                "error": "End date must be after the start date"
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "upload-your-documents",
      "title": "Upload your documents",
      "elements": [
        {
          "ref": "components/generic-file",
          "overrides": {
            "label": "Photo of the land",
            "fieldId": "photo-of-land",
            "validations": {
              "fileTypes": {
                "value": [
                  "image/png",
                  "image/jpeg",
                  "application/pdf"
                ],
                "error": "Upload a PNG, JPG or PDF file"
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "description": "Review all the information you have provided before submitting your application.",
      "elements": [],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "label": "Declaration",
            "fieldId": "declaration-confirmed",
            "options": [
              {
                "label": "I confirm that the information provided in this application is true and correct to the best of my knowledge.",
                "value": "confirmed"
              }
            ],
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application submitted",
      "elements": [],
      "behaviours": [],
      "nextSteps": [
        {
          "title": "What happens next",
          "content": "We have received your submission. You will receive a confirmation email at the address you provided."
        }
      ]
    }
  ],
  "createdAt": "2026-06-15T13:33:44.837Z",
  "updatedAt": "2026-06-15T13:33:44.837Z"
}
