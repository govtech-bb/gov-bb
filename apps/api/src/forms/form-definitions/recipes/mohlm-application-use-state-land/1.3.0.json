{
  "formId": "mohlm-application-use-state-land",
  "title": "MOHLM Application to Use State Land",
  "description": "Ministry of Housing, Lands and Maintenance application form for using state land",
  "version": "1.3.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "contact-information.email",
        "subject": "Your application to use state land has been received"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "About you",
      "elements": [
        {
          "ref": "components/title"
        },
        {
          "ref": "components/first-name"
        },
        {
          "ref": "components/middle-name"
        },
        {
          "ref": "components/last-name"
        },
        {
          "ref": "components/sex"
        },
        {
          "ref": "components/national-id-number"
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "applicant-address-line-1",
            "label": "Address line 1"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "applicant-address-line-2",
            "label": "Address line 2",
            "ui": {
              "hideLabel": true
            }
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "applicant-parish"
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "fieldId": "applicant-postcode"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "applicant-type",
      "title": "Who is applying?",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "applying-as",
            "label": "Are you applying as an individual or organisation?",
            "options": [
              {
                "label": "Individual",
                "value": "individual"
              },
              {
                "label": "Organisation",
                "value": "organisation"
              }
            ],
            "validations": {
              "required": {
                "value": true,
                "error": "Select whether you are applying as an individual or organisation"
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "organisation-name",
            "label": "Organisation name",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the organisation name"
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "contact-information",
      "title": "How to contact you",
      "elements": [
        {
          "ref": "components/email"
        },
        {
          "ref": "components/home-telephone"
        },
        {
          "ref": "components/work-telephone"
        },
        {
          "ref": "components/mobile-telephone"
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "property-details",
      "title": "Property details",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "property-address-line-1",
            "label": "Address line 1",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the property address"
              }
            }
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "property-address-line-2",
            "label": "Address line 2",
            "ui": {
              "hideLabel": true
            }
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "property-parish",
            "validations": {
              "required": {
                "value": true,
                "error": "Select the parish"
              }
            }
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "fieldId": "property-postcode"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "gps-coordinates",
            "label": "GPS coordinates",
            "hint": "Enter the GPS coordinates of the property if available"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "proposed-use",
      "title": "Proposed use",
      "elements": [
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "fieldId": "activities-to-be-carried-out",
            "label": "What activities will be carried out on the land?",
            "validations": {
              "required": {
                "value": true,
                "error": "Describe the activities to be carried out"
              }
            },
            "ui": {
              "width": "long"
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "usage-period",
      "title": "Usage period",
      "elements": [
        {
          "ref": "components/generic-date",
          "overrides": {
            "fieldId": "start-date",
            "label": "Start date",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the start date"
              }
            }
          }
        },
        {
          "ref": "components/generic-date",
          "overrides": {
            "fieldId": "end-date",
            "label": "End date",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the end date"
              },
              "min": {
                "referenceFieldId": "start-date",
                "error": "End date must be on or after the start date"
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "duration",
            "label": "Duration",
            "hint": "For example, 6 months or 2 years"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "description": "Review all the information you have provided before submitting your application.",
      "elements": [],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "Declaration",
            "options": [
              {
                "label": "I confirm that the information provided in this application is true and correct to the best of my knowledge.",
                "value": "confirmed"
              }
            ],
            "validations": {
              "required": {
                "value": true,
                "error": "You must confirm the declaration to continue"
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application submitted",
      "elements": [],
      "behaviours": []
    }
  ],
  "createdAt": "2026-06-10T15:03:00.215Z",
  "updatedAt": "2026-06-10T15:03:00.215Z"
}
