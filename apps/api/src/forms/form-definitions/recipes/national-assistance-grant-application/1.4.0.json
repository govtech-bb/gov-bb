{
  "formId": "national-assistance-grant-application",
  "title": "Application for National Assistance Grant",
  "description": "Apply for a national assistance grant from the Social Empowerment Agency",
  "version": "1.4.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "contact-information.email",
        "subject": "Your national assistance grant application has been received"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "Your details",
      "elements": [
        {
          "ref": "components/title"
        },
        {
          "ref": "components/first-name"
        },
        {
          "ref": "components/middle-name"
        },
        {
          "ref": "components/last-name"
        },
        {
          "ref": "components/generic-date",
          "overrides": {
            "fieldId": "date-of-birth",
            "label": "Date of birth",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter your date of birth"
              },
              "pastOrToday": {
                "value": true,
                "error": "Date of birth must be in the past"
              }
            }
          }
        },
        {
          "ref": "components/sex"
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "address-details",
      "title": "Your address",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "address-line-1",
            "label": "Address line 1",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter your address"
              }
            }
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "address-line-2",
            "label": "Address line 2"
          }
        },
        {
          "ref": "components/parish"
        },
        {
          "ref": "components/town",
          "overrides": {
            "label": "Town"
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "ui": {
              "width": "short"
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "contact-information",
      "title": "Contact information",
      "elements": [
        {
          "ref": "components/national-id-number",
          "overrides": {
            "validations": {
              "required": {
                "value": true,
                "error": "Enter your national registration number"
              }
            }
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "validations": {
              "required": {
                "value": true,
                "error": "Enter your email address"
              }
            }
          }
        },
        {
          "ref": "components/home-telephone"
        },
        {
          "ref": "components/mobile-telephone",
          "overrides": {
            "validations": {
              "required": {
                "value": true,
                "error": "Enter your cell phone number"
              }
            }
          }
        },
        {
          "ref": "components/work-telephone"
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "assistance-details",
      "title": "Assistance information",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "type-of-assistance",
            "label": "Type of assistance required",
            "validations": {
              "required": {
                "value": true,
                "error": "Specify the type of assistance you require"
              }
            }
          }
        },
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "fieldId": "reason-for-application",
            "label": "Reason for application",
            "validations": {
              "required": {
                "value": true,
                "error": "Explain why you are applying for assistance"
              }
            },
            "ui": {
              "width": "long"
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "description": "Review all the information you have provided before submitting your application.",
      "elements": [],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "Declaration",
            "options": [
              {
                "label": "I confirm that the information provided in this application is true and correct to the best of my knowledge.",
                "value": "confirmed"
              }
            ],
            "validations": {
              "required": {
                "value": true,
                "error": "You must confirm the declaration to continue"
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application submitted",
      "elements": [],
      "behaviours": []
    }
  ],
  "createdAt": "2026-06-11T17:31:49.722Z",
  "updatedAt": "2026-06-11T17:31:49.722Z"
}
