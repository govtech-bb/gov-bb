        },
        {
          "ref": "components/generic-date",
          "overrides": {
            "label": "Date of birth",
            "fieldId": "date-of-birth",
            "validations": {
              "required": {
                "error": "Enter your date of birth",
                "value": true
              },
              "pastOrToday": {
                "error": "Date of birth must be in the past",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/sex",
          "overrides": {
            "hint": "Optional"
          }
        },
        {
          "ref": "components/national-id-number"
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "address-and-contact-details",
