{
  "formId": "national-assistance-grant-application",
  "title": "Application for National Assistance Grant",
  "description": "Apply for a national assistance grant from the Social Empowerment Agency",
  "version": "1.5.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your national assistance grant application has been received",
