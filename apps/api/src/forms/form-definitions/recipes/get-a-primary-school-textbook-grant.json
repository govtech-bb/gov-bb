{
  "formId": "get-a-primary-school-textbook-grant",
  "title": "Get a Primary School Textbook Grant",
  "description": "Each year, every child is entitled to a BDS $100 textbook grant while they are a student at a public or private primary school.",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "applicant-details.applicant-email",
        "subject": "Your textbook grant application has been received",
        "label": "Applicant Email"
      }
    },
    {
      "type": "email",
      "config": {
        "recipientField": {
          "schoolEmail": {
            "var": "values.child-details.0.child-school"
          }
        },
        "subject": "A textbook grant application has been received",
        "label": "School Email"
      }
    },
    {
      "type": "email",
      "config": {
        "recipientField": "config.mdaEmail",
        "label": "MDA Email",
        "subject": "A textbook grant application has been submitted"
      }
    }
