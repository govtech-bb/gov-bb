      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Your application has been submitted",
      "description": "Your application to sit CSEC exams as a private candidate has been submitted.",
      "elements": [],
      "markdownContent": "## What happens next\n\n- Your application will be reviewed.\n- You may be contacted for further information.\n- You will be advised of your registration and any fees due.\n\n### Need help?\n\nContact the Ministry of Educational Transformation about your application.\n\nKeep a copy of this application for your records.",
      "behaviours": []
    }
