      "title": "Declaration",
      "elements": [
        {
          "ref": "components/show-hide",
          "overrides": {
            "label": "Important notices",
            "content": "Candidates should inform the CXC Local Registrar of any name changes that have occurred since their last examination sitting.\n\nCandidates should check all timetables before registering to avoid subject clashes with other examination boards.\n\nNo alternative arrangements will be made in respect of clashes.",
            "fieldId": "important-notices"
          }
        },
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "",
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            },
            "options": [
              {
                "label": "I confirm that the information I have provided is true and complete to the best of my knowledge. I understand that providing false information may result in my registration being rejected.",
                "value": "confirmed"
              }
            ]
          }
        }
