{
  "formId": "camp-director-application",
  "title": "Apply to be a Camp Director or Assistant Camp Director",
  "description": "Application form to volunteer as a Camp Director or Assistant Camp Director with the National Summer Camp Programme 2026.",
  "version": "1.1.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Application received for Camp Director or Assistant Camp Director",
        "bodyTemplate": "Dear {first-name},\n\nWe have received your application to volunteer as a {position-applied-for} with the National Summer Camp Programme 2026.\n\nThe Ministry of Youth, Sports and Community Empowerment will review your application. They may contact you if they need more information.\n\nIf you need help, contact:\nEmail: [confirmed email address]\nPhone: [confirmed phone number]\n\nThank you.",
        "recipientField": "contact-details.email"
      }
    }
  ],
  "steps": [
    {
      "stepId": "application-type",
      "title": "What you are applying for",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Which position are you applying for?",
            "fieldId": "position-applied-for",
            "options": [
              {
                "label": "Camp Director",
                "value": "camp-director"
              },
              {
                "label": "Assistant Camp Director",
                "value": "assistant-camp-director"
              }
            ],
            "validations": {
              "required": {
                "error": "Select a position",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Which area are you interested in?",
            "fieldId": "area-of-interest",
            "options": [
              {
                "label": "General",
                "value": "general"
              },
              {
                "label": "Cultural Arts",
                "value": "cultural-arts"
              },
              {
                "label": "Working with children who need additional support",
                "value": "additional-support"
              }
            ],
            "validations": {
              "required": {
                "error": "Select an area",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "hint": "This is not guaranteed.",
            "label": "Preferred parish or camp venue",
            "fieldId": "preferred-parish-or-venue"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "personal-details",
      "title": "Tell us about yourself",
