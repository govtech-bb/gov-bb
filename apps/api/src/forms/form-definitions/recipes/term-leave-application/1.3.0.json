{
  "formId": "term-leave-application",
  "title": "Application for Term's Leave",
  "version": "1.3.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your Term Leave Application has been received",
        "recipientField": "applicant-info.email"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-info",
      "title": "Applicant Information",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "School",
            "fieldId": "school",
            "fullWidth": true,
            "validations": {
              "required": {
                "error": "School is required",
                "value": true
              },
              "minLength": {
                "error": "School must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "label": "First Name",
            "fieldId": "firstName",
            "columnWidth": "50%",
            "validations": {
              "required": {
                "error": "First Name is required",
                "value": true
              },
              "minLength": {
                "error": "First Name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "label": "Last Name",
            "fieldId": "lastName",
            "columnWidth": "50%",
            "validations": {
              "required": {
                "error": "Last Name is required",
                "value": true
              },
              "minLength": {
                "error": "Last Name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "label": "Contact No",
            "fieldId": "contactNo",
            "columnWidth": "50%",
            "validations": {
              "required": {
                "error": "Contact No is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "label": "Email",
            "fieldId": "email",
            "columnWidth": "50%",
            "validations": {
              "required": {
                "error": "Email is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Post",
            "fieldId": "post",
            "columnWidth": "50%",
            "validations": {
              "required": {
                "error": "Post is required",
                "value": true
              },
              "minLength": {
                "error": "Post must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "label": "ID Number",
            "fieldId": "idNumber",
            "columnWidth": "50%",
            "validations": {
              "required": {
                "error": "ID Number is required",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "leave-details",
      "title": "Leave Details",
      "elements": [
        {
          "ref": "components/generic-date",
          "overrides": {
            "label": "Start Date",
            "fieldId": "leaveStartDate",
            "hint": "For example, 1 9 2026",
            "validations": {
              "required": {
                "error": "Start Date is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-date",
          "overrides": {
            "label": "End Date",
            "fieldId": "leaveEndDate",
            "hint": "For example, 15 12 2026",
            "validations": {
              "required": {
                "error": "End Date is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Have you previously been granted term's leave?",
            "fieldId": "previousLeaveGranted",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Select yes or no",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/show-hide",
          "overrides": {
            "label": "If yes, enter the last leave period",
            "fieldId": "previousLeaveDetails",
            "elements": [
              {
                "ref": "components/generic-date",
                "overrides": {
                  "label": "Start Date",
                  "fieldId": "previousLeaveStartDate"
                }
              },
              {
                "ref": "components/generic-date",
                "overrides": {
                  "label": "End Date",
                  "fieldId": "previousLeaveEndDate"
                }
              }
            ],
            "showWhen": {
              "value": "yes",
              "fieldId": "previousLeaveGranted"
            }
          }
        },
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "rows": 4,
            "label": "Comments",
            "fieldId": "comments",
            "fullWidth": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "",
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            },
            "options": [
              {
                "label": "I confirm that my information is correct and I am happy for it to be verified. I understand that false details may lead to my application being rejected, and that the Government of Barbados will keep my information confidential.",
                "value": "confirmed"
              }
            ]
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "fieldId": "declaration-date",
            "label": "Date of declaration",
            "isHidden": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Submission Confirmation",
      "elements": [],
      "behaviours": []
    }
  ],
  "createdAt": "2026-06-03T00:00:00.000Z",
  "updatedAt": "2026-06-03T00:00:00.000Z"
}
