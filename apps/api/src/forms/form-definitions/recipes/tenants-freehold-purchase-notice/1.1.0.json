{
  "formId": "tenants-freehold-purchase-notice",
  "title": "Tenant's Notice to Landlord of Intention to Purchase the Freehold of His Lot",
  "description": "Form 1 under the Tenantries Freehold Purchase Act, Cap. 239B - Notice of intention to purchase freehold",
  "version": "1.1.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "landlord-details.landlord-name",
        "subject": "Notice of Intention to Purchase Freehold - Tenantries Freehold Purchase Act"
      }
    }
  ],
  "steps": [
    {
      "stepId": "landlord-details",
      "title": "Landlord Details",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "landlord-name",
            "label": "Name of person who owns the tenantry",
            "hint": "Insert name of person who owns the tenantry",
            "validations": {
              "required": {
                "value": true,
                "error": "Landlord name is required"
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "tenantry-details",
      "title": "Tenantry Details",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "tenantry-name",
            "label": "Name of the tenantry",
            "hint": "Give name of the tenantry within which the lot is comprised",
            "validations": {
              "required": {
                "value": true,
                "error": "Tenantry name is required"
              }
            }
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "tenantry-parish",
            "label": "Parish",
            "hint": "Name parish in which the tenantry is situated",
            "validations": {
              "required": {
                "value": true,
                "error": "Parish is required"
              }
            },
            "options": [
              {
                "label": "Christ Church",
