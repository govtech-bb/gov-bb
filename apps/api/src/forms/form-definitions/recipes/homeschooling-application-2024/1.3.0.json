{
  "formId": "homeschooling-application-2024",
  "title": "Ministry of Education Transformation - Homeschooling Application Form",
  "version": "1.3.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your Homeschooling Application has been received",
        "recipientField": "applicant-info.email-address"
      }
    },
    {
      "type": "email",
      "config": {
        "recipientField": "testing@govtech.bb",
        "subject": "New submission to Homeschooling Application Form"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-info",
      "title": "Applicant Information",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "label": "Title",
            "fieldId": "title"
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "label": "First Name",
            "fieldId": "first-name"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "label": "Last Name",
            "fieldId": "last-name"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Address",
            "fieldId": "applicant-address",
            "validations": {
              "required": {
                "error": "Address is required",
                "value": true
              },
              "minLength": {
                "error": "Address must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "label": "Parish",
            "fieldId": "applicant-parish",
            "ui": {
              "width": "medium"
            }
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "label": "Contact Number(s)",
            "fieldId": "contact-numbers",
            "validations": {
              "required": {
                "error": "Contact Number(s) is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "type": "email",
            "label": "Email Address",
            "fieldId": "email-address",
            "validations": {
              "required": {
                "error": "Email Address is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Status Resident",
            "fieldId": "resident-status",
            "options": [
              {
                "label": "Resident",
                "value": "resident"
              },
              {
                "label": "Non-Resident",
                "value": "non-resident"
              }
            ],
            "validations": {
              "required": {
                "error": "Status Resident is required",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "student-info",
      "title": "Student Information",
      "description": "Name and Date of Birth of Student(s) to be Homeschooled",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Student Name",
            "fieldId": "student-name",
            "validations": {
              "required": {
                "error": "Student Name is required",
                "value": true
              },
              "minLength": {
                "error": "Student Name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "type": "date",
            "label": "Date of Birth",
            "hint": "For example, 30 12 1986",
            "fieldId": "student-dob",
            "validations": {
              "required": {
                "error": "Date of Birth is required",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": [
        {
          "type": "repeatable",
          "min": 1,
          "max": 10,
          "addAnotherLabel": "Do you want to add another student?"
        }
      ]
    },
    {
      "stepId": "previous-schooling",
      "title": "Previous Schooling",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Was the student(s) previously in school?",
            "fieldId": "previously-in-school",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Was the student(s) previously in school? is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "What is the name and address of the school?",
            "fieldId": "previous-school-info",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "previously-in-school"
              }
            ],
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "instructor-info",
      "title": "Instructor/Tutor Information",
      "description": "Names of Instructors/Tutors (Please provide certified copies of qualifications)",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Instructor/Tutor Name",
            "fieldId": "instructor-name",
            "validations": {
              "required": {
                "error": "Instructor/Tutor Name is required",
                "value": true
              },
              "minLength": {
                "error": "Instructor/Tutor Name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "List of Qualifications",
            "fieldId": "instructor-qualifications",
            "validations": {
              "required": {
                "error": "List of Qualifications is required",
                "value": true
              },
              "minLength": {
                "error": "List of Qualifications must be at least 2 characters",
                "value": 2
              }
            }
          }
        }
      ],
      "behaviours": [
        {
          "type": "repeatable",
          "min": 1,
          "max": 10,
          "addAnotherLabel": "Do you want to add another instructor?"
        }
      ]
    },
    {
      "stepId": "curriculum-attachments",
      "title": "Curriculum and Attachments",
      "elements": [
        {
          "ref": "components/generic-file",
          "overrides": {
            "label": "Timetable (detailing subjects and times)",
            "fieldId": "timetable-attachment",
            "validations": {
              "required": {
                "error": "Timetable (detailing subjects and times) is required",
                "value": true
              },
              "fileTypes": {
                "error": "Upload a .pdf, .docx, or .png file",
                "value": [".pdf", ".docx", ".png"]
              },
              "maxSize": {
                "error": "The file must be 25MB or smaller",
                "value": 26214400
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Are you following the National Curriculum?",
            "fieldId": "following-national-curriculum",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Are you following the National Curriculum? is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-file",
          "overrides": {
            "label": "Curriculum (if not following National Curriculum)",
            "fieldId": "curriculum-attachment",
            "validations": {
              "required": {
                "value": false
              },
              "fileTypes": {
                "error": "Upload a .pdf, .docx, or .png file",
                "value": [".pdf", ".docx", ".png"]
              },
              "maxSize": {
                "error": "The file must be 25MB or smaller",
                "value": 26214400
              }
            },
            "helperText": "Please attach the curriculum you will be following if you are not following the National Curriculum",
            "conditional": {
              "value": "no",
              "fieldId": "following-national-curriculum",
              "operator": "equals"
            }
          }
        },
        {
          "ref": "components/generic-file",
          "overrides": {
            "label": "Certified Copies of Tutor Qualifications",
            "fieldId": "tutor-qualifications-attachment",
            "validations": {
              "required": {
                "error": "Certified Copies of Tutor Qualifications is required",
                "value": true
              },
              "fileTypes": {
                "error": "Upload a .pdf, .docx, or .png file",
                "value": [".pdf", ".docx", ".png"]
              },
              "maxSize": {
                "error": "The file must be 25MB or smaller",
                "value": 26214400
              }
            },
            "helperText": "Please attach certified copies of qualifications of persons who will be teaching"
          }
        },
        {
          "ref": "components/generic-file",
          "overrides": {
            "label": "Previous Progress Report (Report Card)",
            "fieldId": "progress-report-attachment",
            "validations": {
              "required": {
                "value": false
              },
              "fileTypes": {
                "error": "Upload a .pdf, .docx, or .png file",
                "value": [".pdf", ".docx", ".png"]
              },
              "maxSize": {
                "error": "The file must be 25MB or smaller",
                "value": 26214400
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "",
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            },
            "options": [
              {
                "label": "I confirm that my information is correct and I am happy for it to be verified. I understand that false details may lead to my application being rejected, and that the Government of Barbados will keep my information confidential.",
                "value": "confirmed"
              }
            ]
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "fieldId": "declaration-date",
            "label": "Date of declaration",
            "isHidden": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Submission Confirmation",
      "elements": [],
      "behaviours": []
    }
  ],
  "createdAt": "2026-06-03T00:00:00.000Z",
  "updatedAt": "2026-06-03T00:00:00.000Z"
}
