{
  "steps": [
    {
      "title": "What do you want to do?",
      "stepId": "request-details",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "What do you want to do?",
            "fieldId": "request-purpose",
            "options": [
              {
                "label": "Search if society name is available",
                "value": "request-search"
              },
              {
                "label": "Reserve a society name",
                "value": "reserve-name"
              },
              {
                "label": "Change the name of an existing society",
                "value": "change-name"
              }
            ],
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "What is the current name of the society?",
            "fieldId": "current-society-name",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "change-name",
                "operator": "equal",
                "targetFieldId": "request-purpose"
              }
            ],
            "validations": {
              "required": {
                "error": "Current society name is required",
                "value": true
              }
            }
          }
        }
      ]
    },
    {
      "title": "What are your proposed society names?",
      "stepId": "proposed-names",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "First choice of society name",
            "fieldId": "society-name-1",
            "validations": {
              "required": {
                "error": "At least one society name is required",
                "value": true
              },
              "minLength": {
                "error": "Must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "How did you choose this name?",
            "fieldId": "society-name-1-explanation",
            "validations": {
              "required": {
                "error": "Explanation is required",
                "value": true
              },
              "minLength": {
                "error": "Must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "hint": "Leave blank if you only have one choice",
            "label": "Second choice of society name (optional)",
            "fieldId": "society-name-2",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "How did you choose this name?",
            "fieldId": "society-name-2-explanation"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "hint": "Leave blank if you only have two choices",
            "label": "Third choice of society name (optional)",
            "fieldId": "society-name-3",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "How did you choose this name?",
            "fieldId": "society-name-3-explanation"
          }
        }
      ],
      "description": "You can suggest up to 3 names. Provide at least one."
    },
    {
      "title": "What does the society do?",
      "stepId": "society-activities",
      "elements": [
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "Activity 1",
            "fieldId": "activity-1",
            "validations": {
              "required": {
                "error": "At least one activity is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "Activity 2 (optional)",
            "fieldId": "activity-2"
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "label": "Activity 3 (optional)",
            "fieldId": "activity-3"
          }
        }
      ],
      "description": "List the main activities of the society (up to 3)"
    },
    {
      "title": "Tell us about yourself",
      "stepId": "applicant-details",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "applicant-title"
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "applicant-first-name",
            "validations": {
              "required": {
                "error": "First name is required",
                "value": true
              },
              "minLength": {
                "error": "First name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "hint": "Optional. Provide only if known",
            "fieldId": "applicant-middle-name"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "applicant-last-name",
            "validations": {
              "required": {
                "error": "Last name is required",
                "value": true
              },
              "minLength": {
                "error": "Last name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "label": "Address Line 1",
            "fieldId": "address-line-1",
