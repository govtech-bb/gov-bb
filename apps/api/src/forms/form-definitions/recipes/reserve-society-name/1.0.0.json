  "title": "Reserve a Society Name",
  "formId": "reserve-society-name",
  "version": "1.0.0",
  "createdAt": "2026-05-07T00:00:00Z",
  "updatedAt": "2026-05-07T00:00:00Z",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your society name request has been received",
        "recipientField": "applicant-details.applicant-email"
