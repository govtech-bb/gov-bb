{
  "steps": [
    {
      "title": "Tell us about yourself",
      "stepId": "applicant",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "applicant-title",
            "validations": {
              "required": {
                "error": "Title is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "applicant-first-name",
            "validations": {
              "required": {
                "error": "First name is required",
                "value": true
              },
              "minLength": {
                "error": "First name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "hint": "If you have more than one, add them in order",
            "fieldId": "applicant-middle-name"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "applicant-last-name",
            "validations": {
              "required": {
                "error": "Last name is required",
                "value": true
              },
              "minLength": {
                "error": "Last name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "hint": "For example, 30 12 1986",
            "fieldId": "applicant-dob",
            "validations": {
              "required": {
                "error": "Date of birth is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "label": "National Identification (ID) Number",
            "fieldId": "applicant-nid",
            "validations": {
              "required": {
                "error": "National ID Number is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/show-hide",
          "overrides": {
            "hint": "If you don't have a National ID number, you can use your passport number instead.",
            "label": "Use passport number instead",
            "fieldId": "passport-toggle"
          }
        },
        {
          "ref": "components/passport-number",
          "overrides": {
            "label": "Passport Number",
            "fieldId": "applicant-passport-number",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": true,
                "operator": "equal",
                "targetFieldId": "passport-toggle"
              }
            ],
            "validations": {
              "required": {
                "error": "Passport number is required",
                "value": true
              },
              "minLength": {
                "error": "Passport number must be at least 6 characters",
                "value": 6
              }
            }
          }
        }
      ]
    },
    {
      "title": "Contact details",
      "stepId": "contact-details",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "label": "Address line 1",
            "fieldId": "contact-address-1",
            "validations": {
              "required": {
                "error": "Address line 1 is required",
                "value": true
              },
              "minLength": {
                "error": "Address must be at least 5 characters",
                "value": 5
              }
            }
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "label": "Address line 2",
            "fieldId": "contact-address-2"
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "contact-parish",
            "options": [
              {
                "label": "Christ Church",
                "value": "christ-church"
              },
              {
                "label": "St. Andrew",
                "value": "st-andrew"
              },
              {
                "label": "St. George",
                "value": "st-george"
              },
              {
                "label": "St. James",
                "value": "st-james"
              },
              {
                "label": "St. John",
                "value": "st-john"
              },
              {
                "label": "St. Joseph",
                "value": "st-joseph"
              },
              {
                "label": "St. Lucy",
                "value": "st-lucy"
              },
              {
                "label": "St. Michael",
                "value": "st-michael"
              },
              {
                "label": "St. Peter",
                "value": "st-peter"
              },
              {
                "label": "St. Philip",
                "value": "st-philip"
              },
              {
                "label": "St. Thomas",
                "value": "st-thomas"
              }
            ],
            "validations": {
              "required": {
                "error": "Parish is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "hint": "For example, BB17004 (optional)",
            "fieldId": "contact-postcode"
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "fieldId": "contact-email",
            "validations": {
              "required": {
                "error": "Email address is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "fieldId": "contact-telephone",
            "validations": {
              "required": {
                "error": "Telephone number is required",
                "value": true
              }
            }
          }
        }
      ]
    },
    {
      "title": "Tell us about your licence history",
      "stepId": "licence-history",
      "elements": [
        {
          "ref": "components/generic/radio",
          "overrides": {
            "label": "Have you had a conductor or driving licence before?",
            "fieldId": "has-previous-licence",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/name",
          "overrides": {
            "label": "Provide your licence number",
            "fieldId": "licence-number",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter your licence number"
              },
              "pattern": {
                "value": "^[A-Za-z0-9 -]+$",
                "error": "Licence number can only contain letters, numbers, spaces and hyphens"
              }
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-previous-licence"
              }
            ]
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "label": "Date of issue",
            "fieldId": "licence-date-of-issue",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-previous-licence"
              }
            ]
          }
        }
      ]
    },
    {
      "title": "Tell us about any endorsements",
      "stepId": "endorsements",
      "elements": [
        {
          "ref": "components/generic/radio",
          "overrides": {
            "label": "Do you have any endorsements?",
            "fieldId": "has-endorsements",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/name",
          "overrides": {
            "label": "Type of licence",
            "fieldId": "endorsement-type",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-endorsements"
              }
            ]
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "label": "Date of endorsement",
            "fieldId": "endorsement-date",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-endorsements"
              }
            ]
          }
        },
        {
          "ref": "components/name",
          "overrides": {
            "label": "How long did the endorsement appear on your licence?",
            "fieldId": "endorsement-duration",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-endorsements"
              }
            ]
          }
        }
      ],
      "behaviours": [
        {
          "max": 5,
          "min": 1,
          "type": "repeatable"
        }
      ],
      "description": "An endorsement is a record of an offence added to your conductor or driving licence."
    },
    {
      "title": "Tell us about your disqualifications",
      "stepId": "disqualifications",
      "elements": [
        {
          "ref": "components/generic/radio",
          "overrides": {
            "label": "Have you ever been disqualified?",
            "fieldId": "has-disqualifications",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/name",
          "overrides": {
            "label": "Court name",
            "fieldId": "disqualification-court",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-disqualifications"
              }
            ]
          }
        },
        {
          "ref": "components/name",
          "overrides": {
            "label": "Court reason for disqualification",
            "fieldId": "disqualification-reason",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-disqualifications"
              }
            ]
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "label": "Date of disqualification",
            "fieldId": "disqualification-date",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-disqualifications"
              }
            ]
          }
        },
        {
          "ref": "components/name",
          "overrides": {
            "label": "Length of disqualification",
            "fieldId": "disqualification-length",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "yes",
                "operator": "equal",
                "targetFieldId": "has-disqualifications"
              }
            ]
          }
        }
      ],
      "description": "A disqualification is when a court has stopped you from getting or holding a licence."
    },
    {
      "title": "Your criminal convictions",
      "stepId": "convictions",
      "elements": [
        {
          "ref": "components/generic/radio",
          "overrides": {
            "label": "Have you ever had any criminal convictions?",
            "fieldId": "has-convictions",
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            }
          }
        }
      ],
      "description": "A conviction is when a court has found you guilty of a criminal offence."
    },
    {
      "title": "Upload supporting documents",
      "stepId": "document-uploads",
      "elements": [
        {
          "ref": "components/upload-document",
          "overrides": {
            "hint": "Attach a .pdf, .docx or .png file.",
            "label": "Upload a Police Certificate of Character",
            "fieldId": "police-certificate",
            "validations": {
              "required": {
                "error": "Police Certificate of Character is required",
                "value": true
              }
            }
          }
        }
      ]
    },
    {
      "title": "Declaration",
      "stepId": "declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "label": "Declaration",
            "fieldId": "declaration-confirmed",
            "options": [
              {
                "label": "I confirm that my information is correct and I am happy for it to be verified. I understand that false details may lead to my application being rejected, and that the Government of Barbados will keep my information confidential.",
                "value": "confirmed"
              }
            ],
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "label": "Date of declaration",
            "fieldId": "declaration-date",
            "isHidden": true
          }
        }
      ]
    },
    {
      "title": "Application submitted",
      "stepId": "submission-confirmation",
      "elements": [],
      "nextSteps": [
        {
          "title": "What happens next",
          "content": "We have received your submission. You will receive a confirmation email at the address you provided."
        }
      ]
    }
  ],
  "title": "Apply for a Conductor Licence",
  "formId": "apply-for-conductor-licence",
  "version": "1.3.0",
  "createdAt": "2026-05-07T00:00:00Z",
  "updatedAt": "2026-05-07T00:00:00Z",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your conductor licence application has been received",
        "recipientField": "contact-details.contact-email"
      }
    }
  ],
  "description": "Apply for a conductor licence to operate public service vehicles in Barbados."
}
