        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "reason-low-scores",
            "label": "Reason 1: Low Academic Scores",
            "options": [
              {
                "label": "My child was scoring less than 20% in both Mathematics and English over six (6) consecutive terms in Class 2 and Class 3.",
                "value": "low-scores"
              }
            ]
          }
        },
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "reason-missed-instruction",
            "label": "Reason 2: Missed Instruction",
            "options": [
              {
                "label": "My child missed a significant portion of their instruction due to trauma, illness, or significant learning difficulties.",
                "value": "missed-instruction"
              }
            ]
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "fieldId": "additional-reason-details",
            "label": "Additional Details (if needed)",
            "hint": "Provide any additional information supporting your request",
            "validations": {
              "required": {
                "value": false
              }
            },
            "ui": {
              "width": "long"
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "applicant-signature",
      "title": "Applicant Declaration",
      "elements": [
        {
          "ref": "components/name",
          "overrides": {
            "fieldId": "applicant-signature",
            "label": "Signature",
            "hint": "Type your name or initials",
            "validations": {
              "required": {
                "value": true,
                "error": "Signature is required"
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "fieldId": "applicant-signature-date",
            "label": "Date",
            "validations": {
              "required": {
                "value": true,
                "error": "Date is required"
              },
              "pastOrToday": {
                "value": true,
                "error": "Date must be today or in the past"
              }
            }
          }
        }
      ],
      "behaviours": []
