{
  "formId": "nhs-tenants-notice-intention-purchase-freehold",
  "title": "Tenant's Notice of Intention to Purchase Freehold",
  "description": "Formal notice under the Tenantries Freehold Purchase Act, Cap. 239B, Section 12(1)",
  "version": "1.2.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "contact-information.email",
        "subject": "Your notice of intention to purchase freehold has been received"
      }
    }
  ],
  "steps": [
    {
      "stepId": "tenant-details",
      "title": "Tell us about yourself",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "tenant-title",
            "label": "Title"
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "tenant-first-name",
            "label": "First name",
            "validations": {
              "required": {
                "error": "Enter your first name",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "fieldId": "tenant-middle-name",
            "label": "Middle name",
            "hint": "Optional"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "tenant-last-name",
            "label": "Last name",
            "validations": {
              "required": {
                "error": "Enter your last name",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "contact-information",
      "title": "What is your contact information?",
      "elements": [
        {
          "ref": "components/email",
          "overrides": {
            "fieldId": "email",
            "label": "Email address",
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "fieldId": "telephone",
            "label": "Telephone number",
            "validations": {
              "required": {
                "error": "Enter a valid telephone number",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "landlord-type",
      "title": "Who is the landlord?",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "landlord-type-selection",
            "label": "Is the landlord an individual or a company?",
            "validations": {
              "required": {
                "value": true,
                "error": "Select whether the landlord is an individual or a company"
              }
            },
            "options": [
              {
                "label": "Individual",
                "value": "individual"
              },
              {
                "label": "Company",
                "value": "company"
              }
            ]
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "landlord-details",
      "title": "Give the landlord's details",
      "elements": [
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "landlord-first-name",
            "label": "First name",
            "validations": {
              "required": {
                "error": "Enter the landlord's first name",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "fieldId": "landlord-middle-name",
            "label": "Middle name",
            "hint": "Optional"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "landlord-last-name",
            "label": "Last name",
            "validations": {
              "required": {
                "error": "Enter the landlord's last name",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": [
        {
          "type": "stepConditionalOn",
          "targetStepId": "landlord-type",
          "targetFieldId": "landlord-type-selection",
          "operator": "equal",
          "value": "individual"
        }
      ]
    },
    {
      "stepId": "landlord-company-details",
      "title": "Give the company's details",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "company-name",
            "label": "Company name",
            "validations": {
              "required": {
                "value": true,
                "error": "Enter the company name"
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "company-representative-person-first-name",
            "label": "Company representative first name",
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "fieldId": "company-representative-middle-name",
            "label": "Company representative middle name",
            "hint": "Optional"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Company representative last name",
            "validations": {
              "required": {
                "value": false
              }
            },
            "fieldId": "company-representative-person-last-name",
            "hint": "Optional"
          }
        }
      ],
      "behaviours": [
        {
          "type": "stepConditionalOn",
          "targetStepId": "landlord-type",
          "targetFieldId": "landlord-type-selection",
          "operator": "equal",
          "value": "company"
        }
      ]
    },
    {
      "stepId": "tenantry-location",
      "title": "Where is the tenantry's location",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "label": "Tenantry name"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "tenantry-address-line-1",
            "label": "Address line 1",
            "validations": {
              "required": {
                "error": "Enter the address",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "tenantry-address-line-2",
            "label": "Address line 2",
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/parish"
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "fieldId": "tenantry-postcode",
            "label": "Postcode",
            "ui": {
              "width": "short"
            },
            "hint": "Optional"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "description": "Review all the information you have provided before submitting your application.",
      "elements": [],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "Declaration",
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            },
            "options": [
              {
                "label": "I confirm that the information provided in this notice is true and correct.",
                "value": "confirmed"
              }
            ]
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application submitted",
      "elements": [],
      "behaviours": [],
      "nextSteps": [
        {
          "title": "What happens next",
          "content": "We have received your notice of intention to purchase the freehold. You will receive a confirmation email at the address you provided."
        }
      ]
    }
  ],
  "createdAt": "2026-06-12T20:19:40.214Z",
  "updatedAt": "2026-06-12T20:19:40.214Z"
}
