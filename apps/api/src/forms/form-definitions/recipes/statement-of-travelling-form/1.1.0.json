{
  "formId": "statement-of-travelling-form",
  "title": "Statement of Travelling Form",
  "version": "1.1.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your Statement of Travelling submission has been received",
        "recipientField": "applicant-info.email"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-info",
      "title": "Personal Information",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Name",
            "fieldId": "name"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "ID Number",
            "fieldId": "id-number"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Email",
            "fieldId": "email"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Phone Number",
            "fieldId": "phone-number"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "travel-certification",
      "title": "Travel Certification",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Month",
            "fieldId": "certification-month",
            "placeholder": "MM"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Year",
            "fieldId": "certification-year",
            "placeholder": "YYYY"
          }
        },
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "label": "I certify that during the month of [month/year] the extent of my travelling in the performance of my public duties:",
            "fieldId": "certification-statement"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "travel-details",
      "title": "Travel Details",
      "description": "Add a row for each day of travel.",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "DAY",
            "fieldId": "day"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Distance Travelled",
            "fieldId": "distance-travelled"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "PARTICULARS",
            "fieldId": "particulars",
            "multiline": true
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "No. of Passengers",
            "fieldId": "num-passengers"
          }
        }
      ],
      "behaviours": [
        {
          "type": "repeatable",
          "min": 1,
          "max": 31
        }
      ]
    },
    {
      "stepId": "travel-rates",
      "title": "Travel Rates & Calculations",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Travel Rates",
            "value": "FIRST 320 KM OR LESS: $2.56 PER KM\nREMAINDER OVER 320 KM: $1.03 PER KM\nPASSENGER RATE: # OF PASSENGERS * $0.11 PER KM",
            "fieldId": "travel-rates-info",
            "multiline": true,
            "readonly": true
          }
        },
        {
          "ref": "components/generic-number",
          "overrides": {
            "label": "Total Distance Travelled",
            "fieldId": "total-distance-travelled",
            "readonly": true
          }
        },
        {
          "ref": "components/generic-number",
          "overrides": {
            "label": "First 320 KM or Less",
            "fieldId": "first320km-or-less",
            "readonly": true
          }
        },
        {
          "ref": "components/generic-number",
          "overrides": {
            "label": "Remainder Over 320 KM",
            "fieldId": "remainder-over320km",
            "readonly": true
          }
        },
        {
          "ref": "components/generic-number",
          "overrides": {
            "label": "Passenger Subtotal",
            "fieldId": "passenger-subtotal",
            "readonly": true
          }
        },
        {
          "ref": "components/generic-number",
          "overrides": {
            "label": "Total Claimed",
            "fieldId": "total-claimed",
            "readonly": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "certifications",
      "title": "Certifications",
      "elements": [
        {
          "ref": "components/generic-checkbox",
          "overrides": {
            "label": "I further certify that all travelling on private business or pleasure has been excluded from the total distance travelled as set out in this claim.",
            "fieldId": "business-exclusion-certify"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Signed",
            "fieldId": "applicant-signature",
            "placeholder": ".........................."
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Date",
            "fieldId": "applicant-date",
            "placeholder": ".........................."
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "official-examination",
      "title": "Official Use - Examination Section",
      "elements": [
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "hint": "I hereby certify that I have examined this claim and have found it to be in respect of travelling on public duty only and by the type of vehicle specified and that the journeys made and distances involved have been necessary for the proper performance of the officer's duties.",
            "label": "Examination Notes",
            "fieldId": "examination-notes"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Examination Section Signature",
            "fieldId": "examination-signature",
            "placeholder": ".........................."
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Date",
            "fieldId": "examination-date",
            "placeholder": ".........................."
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "dps-approval",
      "title": "DPS Approval",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "DPS Signature",
            "fieldId": "dps-signature",
            "placeholder": ".........................."
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Date",
            "fieldId": "dps-date",
            "placeholder": ".........................."
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "processing-officer",
      "title": "Processing Officer",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Processing Officer Signature",
            "fieldId": "processing-officer-signature",
            "placeholder": ".........................."
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Date",
            "fieldId": "processing-officer-date",
            "placeholder": ".........................."
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "school-reference",
      "title": "School Distance Reference",
      "elements": [
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "School Distances by Parish",
            "value": "Reference table for distances to various schools by parish - see form pages 3-5 for complete listing",
            "fieldId": "school-reference-info",
            "multiline": true,
            "readonly": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [],
      "behaviours": []
