{
  "formId": "chat-feedback",
  "title": "Give feedback on the assistant",
  "description": "Tell us about your experience with the alpha.gov.bb assistant. This takes about 30 seconds.",
  "version": "1.0.0",
  "createdAt": "2026-06-10T00:00:00Z",
  "updatedAt": "2026-06-10T00:00:00Z",
  "steps": [
    {
      "stepId": "your-feedback",
      "title": "Your feedback",
      "elements": [
        {
          "ref": "components/generic-select",
          "overrides": {
            "fieldId": "experience-rating",
            "label": "How was your experience with the assistant?",
            "options": [
              { "label": "Very good", "value": "very-good" },
              { "label": "Good", "value": "good" },
              { "label": "Okay", "value": "okay" },
              { "label": "Poor", "value": "poor" },
              { "label": "Very poor", "value": "very-poor" }
            ],
            "validations": {
              "required": {
                "value": true,
                "error": "Choose how your experience was"
              }
            }
          }
        },
        {
          "ref": "components/additional-details",
          "overrides": {
            "fieldId": "improvement-comment",
            "label": "What could we do to improve? (optional)",
            "ui": { "width": "long" }
          }
        }
      ]
    },
    {
      "stepId": "submission-confirmation",
      "title": "Feedback submitted",
      "elements": [],
      "nextSteps": [
        {
          "title": "Thank you",
          "content": "Thank you for your feedback. It helps us improve the assistant."
        }
      ]
    }
  ],
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "config.feedback",
        "subject": "New feedback on the alpha.gov.bb assistant"
      }
    }
  ]
}
