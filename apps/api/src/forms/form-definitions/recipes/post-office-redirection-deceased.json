{
  "formId": "post-office-redirection-deceased",
  "title": "Tell the Post Office someone has died",
  "description": "Request to redirect mail for a deceased person",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "applicant-details.email",
        "subject": "Your mail redirection request has been received"
      }
    },
    {
      "type": "email",
      "config": {
        "recipientField": "config.mdaEmail",
