{
  "formId": "smart-stream-vendor-registration",
  "title": "Smart Stream Vendor Registration Form",
  "version": "1.0",
  "organization": "Ministry of Finance, Economic Affairs and Investment",
  "department": "Treasury Department - Information Systems Unit",
  "steps": [
    {
      "stepId": "step-1-basic-info",
      "title": "Basic Information",
      "elements": [
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "min-dept",
            "label": "Min/Dept.",
            "required": true
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "vendor-name",
            "label": "Vendor Name",
            "required": true
          }
        }
      ]
    },
    {
      "stepId": "step-2-classification",
      "title": "Vendor Classification",
      "elements": [
        {
          "ref": "components/generic/radio",
          "overrides": {
            "fieldId": "vendor-classification",
            "label": "Vendor Classification - Please tick appropriate box",
            "required": true,
            "options": [
              {
                "value": "individual",
                "label": "Individual"
              },
              {
                "value": "small-business",
                "label": "Small Business"
              },
              {
                "value": "other-business",
                "label": "Other Business"
              },
              {
                "value": "medium-business",
                "label": "Medium Size Business"
              },
              {
                "value": "large-business",
                "label": "Large Business"
              }
            ]
          }
        }
      ]
    },
    {
      "stepId": "step-3-identification",
      "title": "Identification Numbers",
      "elements": [
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "tamis-number",
            "label": "TAMIS Number",
            "required": false
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "company-reg-number",
            "label": "Company Registration No.",
            "required": false
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "sba-number",
            "label": "Small Business Association No.",
            "required": false
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "nrn",
            "label": "NRN",
            "required": false
          }
        }
      ]
    },
    {
      "stepId": "step-4-contact-address",
      "title": "Contact and Address Information",
      "elements": [
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "vendor-address-line-1",
            "label": "Vendor Address",
            "required": true
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "vendor-address-line-2",
            "label": "Vendor Address (continued)",
            "required": false
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "vendor-email",
            "label": "Vendor Email Address",
            "required": true,
            "type": "email"
          }
        }
      ]
    },
    {
      "stepId": "step-5-bank-details",
      "title": "Bank Account Details",
      "elements": [
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "bank-name",
            "label": "Bank Name",
            "required": true
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "bank-account-number",
            "label": "Bank Account Number",
            "required": true
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "branch-name",
            "label": "Branch Name",
            "required": true
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "name-on-account",
            "label": "Name on Account",
            "required": true
          }
        },
        {
          "ref": "components/generic/radio",
          "overrides": {
            "fieldId": "account-type",
            "label": "Account Type",
            "required": true,
            "options": [
              {
                "value": "deposit",
                "label": "Deposit"
              },
              {
                "value": "savings",
                "label": "Savings"
              }
            ]
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "bic-swift",
            "label": "BIC/ Swift",
            "required": false
          }
        },
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "bank-address",
            "label": "Bank Address",
            "required": true
          }
        }
      ]
    },
    {
      "stepId": "step-6-authorization",
      "title": "Authorization",
      "elements": [
        {
          "ref": "components/generic/text",
          "overrides": {
            "fieldId": "authorized-by",
            "label": "Authorized by",
            "required": true
          }
        }
      ]
    }
  ]
}
