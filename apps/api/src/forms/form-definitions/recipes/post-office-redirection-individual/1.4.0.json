{
  "formId": "post-office-redirection-individual",
  "title": "Redirect my personal mail",
  "version": "1.4.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "applicant-details.applicant-email",
        "subject": "Your Post Office Redirection Application has been received"
      }
    },
    {
      "type": "email",
      "config": {
        "recipientField": "config.mdaEmail",
        "subject": "Your Post Office Redirection Application has been received"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "Tell us about yourself",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "applicant-title",
            "label": "Title",
            "validations": {
              "required": {
                "error": "Title is required",
                "value": true
              }
            },
            "ui": {
              "width": "medium"
            }
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "applicant-first-name",
            "label": "First name",
            "validations": {
              "pattern": {
                "error": "First name must contain only letters, hyphens, or apostrophes",
                "value": "^[a-zA-Z\\-']+$"
              },
              "required": {
                "error": "First name is required",
                "value": true
              },
              "minLength": {
                "error": "First name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "fieldId": "applicant-middle-name",
            "label": "Middle name(s)",
            "hint": "Enter all middle names in order",
            "validations": {
              "pattern": {
                "error": "Middle name must contain only letters, hyphens, or apostrophes",
                "value": "^[a-zA-Z\\-']+$"
              },
              "minLength": {
                "error": "Middle name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "applicant-last-name",
            "label": "Last name",
            "validations": {
              "pattern": {
                "error": "Last name must contain only letters, hyphens, or apostrophes",
                "value": "^[a-zA-Z\\-']+$"
              },
              "required": {
                "error": "Last name is required",
                "value": true
              },
              "minLength": {
                "error": "Last name must be at least 2 characters",
                "value": 2
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "fieldId": "applicant-date-of-birth",
            "label": "Date of birth",
            "hint": "For example, 30 12 1986",
            "validations": {
              "required": {
                "error": "Date of birth is required",
                "value": true
              },
              "pastOrToday": {
                "error": "Date of birth must be in the past",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "fieldId": "applicant-id-number",
            "label": "National Identification (ID) Number",
            "validations": {
              "pattern": {
                "error": "Enter a valid ID number (for example, 850101-0001)",
                "value": "^[0-9]{6}-[0-9]{4}$"
              },
              "required": {
                "error": "ID Number is required",
                "value": true
              }
            },
            "behaviours": [
              {
                "type": "optionalIf",
                "targetFieldId": "passport-toggle",
                "operator": "equal",
                "value": true
              }
            ],
            "ui": {
              "width": "medium"
            }
          }
        },
        {
          "ref": "components/show-hide",
          "overrides": {
            "fieldId": "passport-toggle",
            "label": "Use passport number instead",
            "hint": "If you don't have a National ID number, you can use your passport number instead."
          }
        },
        {
          "ref": "components/passport-number",
          "overrides": {
            "fieldId": "applicant-passport-number",
            "label": "Passport Number",
            "validations": {
              "minLength": {
                "error": "Passport number must be at least 6 characters",
                "value": 6
              },
              "required": {
                "value": true
              }
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetFieldId": "passport-toggle",
                "targetStepId": "applicant-details",
                "operator": "equal",
                "value": true
              }
            ],
            "ui": {
              "width": "medium"
            }
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "fieldId": "applicant-email",
            "label": "Email address",
            "validations": {
              "email": {
                "error": "Enter a valid email address",
                "value": true
              },
              "required": {
                "error": "Email address is required",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "fieldId": "applicant-telephone-number",
            "label": "Telephone number",
            "validations": {
              "pattern": {
                "error": "Please enter a valid phone number (for example, 2345678, 1-246-234-5678, or 1 246 234 5678)",
                "value": "^\\d{3}[- ]?\\d{4}$|^(?:\\d{1,2}[- ]?)?\\d{3}[- ]?\\d{3}[- ]?\\d{4}$"
              },
              "required": {
                "error": "Telephone number is required",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
