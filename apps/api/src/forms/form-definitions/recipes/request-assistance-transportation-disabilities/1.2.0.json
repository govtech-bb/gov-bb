{
  "formId": "request-assistance-transportation-disabilities",
  "title": "Request for Assistance / Transportation for Persons with Disabilities",
  "description": "Application for assistance and transportation services through the Social Empowerment Agency",
  "version": "1.2.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "applicant-details.applicant-email",
        "subject": "Your request for assistance has been received"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "Tell us your details",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "applicant-title",
            "label": "Title"
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "applicant-first-name",
            "label": "First name",
            "validations": {
              "required": {
                "error": "Enter your first name",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "fieldId": "applicant-middle-name",
            "label": "Middle name"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "applicant-last-name",
            "label": "Last name",
            "validations": {
              "required": {
                "error": "Enter your last name",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/date-of-birth"
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "fieldId": "applicant-national-id",
            "label": "National Registration Number",
            "validations": {
              "required": {
                "error": "Enter your National Registration Number",
                "value": true
              }
            },
            "hint": "Enter your valid National ID Number (for example, 450702-0130)"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "applicant-contact-information",
      "title": "Give us your contact information",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "address-line-1",
            "label": "Address line 1"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "address-line-2",
            "label": "Address line 2",
            "hint": "Optional",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/parish"
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "hint": "Optional"
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "fieldId": "applicant-telephone-number"
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "next-of-kin",
      "title": "Who is your next of kin?",
      "elements": [
        {
          "ref": "components/title",
          "overrides": {
            "fieldId": "kin-title",
            "label": "Title"
          }
        },
        {
          "ref": "components/first-name",
          "overrides": {
            "fieldId": "kin-first-name",
            "label": "First name",
            "validations": {
              "required": {
                "error": "Enter first name",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "fieldId": "kin-middle-name",
            "label": "Middle name",
            "hint": "Optional"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "fieldId": "kin-last-name",
            "label": "Last name",
            "validations": {
              "required": {
                "error": "Enter last name",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/relationship",
          "overrides": {
            "fieldId": "kin-relationship",
            "label": "Relationship",
            "validations": {
              "required": {
                "error": "Select your relationship to the applicant",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "kin-relationship-other",
            "label": "Please specify the relationship",
            "validations": {
              "required": {
                "error": "Specify the relationship",
                "value": true
              }
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetFieldId": "kin-relationship",
                "operator": "equal",
                "value": "other"
              }
            ]
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "next-of-kin-contact-information",
      "title": "Give us your next of kin's contact information",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "kin-address-line-1",
            "label": "Address line 1"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "fieldId": "kin-address-line-2",
            "label": "Address line 2",
            "validations": {
              "required": {
                "value": false
              }
            },
            "hint": "Optional"
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "fieldId": "kin-parish"
          }
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "hint": "Optional",
            "fieldId": "kin-postcode"
          }
        },
        {
          "ref": "components/telephone",
          "overrides": {
            "fieldId": "kin-telephone"
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "fieldId": "kin-email",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "request-details",
      "title": "Tell us about your request",
      "elements": [
        {
          "ref": "components/generic-select",
          "overrides": {
            "fieldId": "nature-of-request",
            "label": "What type of assistance are you requesting?",
            "validations": {
              "required": {
                "error": "Select the type of assistance you need",
                "value": true
              }
            },
            "options": [
              {
                "label": "Assistance only",
                "value": "assistance"
              },
              {
                "label": "Transportation only",
                "value": "transportation"
              },
              {
                "label": "Both assistance and transportation",
                "value": "both"
              }
            ]
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "using-assistive-device",
            "label": "Are you using an assistive device?",
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            },
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ]
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "type-of-assistive-device",
            "label": "Type of assistive device",
            "validations": {
              "required": {
                "error": "Enter the type of assistive device",
                "value": true
              }
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetFieldId": "using-assistive-device",
                "operator": "equal",
                "value": "yes"
              }
            ]
          }
        },
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "fieldId": "nature-of-disability",
            "label": "Nature of disability",
            "validations": {
              "required": {
                "error": "Describe your disability",
                "value": true
              }
            },
            "ui": {
              "width": "long"
            }
          }
        },
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "fieldId": "health-condition",
            "label": "Health condition",
            "validations": {
              "required": {
                "error": "Enter your health condition",
                "value": true
              }
            },
            "ui": {
              "width": "long"
            }
          }
        },
        {
          "ref": "components/generic-number",
          "overrides": {
            "fieldId": "household-persons",
            "label": "Number of persons in your household",
            "validations": {
              "required": {
                "error": "Enter the number of persons",
                "value": true
              },
              "min": {
                "error": "Must be at least 1",
                "value": 1
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "evacuation-needed",
            "label": "In the event of an emergency or natural disaster, would you need evacuation from your home?",
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            },
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ]
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "vehicle-access",
            "label": "Can your home be accessed by vehicle?",
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            },
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ]
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "employment-status",
            "label": "Employment status",
            "validations": {
              "required": {
                "error": "Select your employment status",
                "value": true
              }
            },
            "options": [
              {
                "label": "Employed",
                "value": "employed"
              },
              {
                "label": "Unemployed",
                "value": "unemployed"
              },
              {
                "label": "Self-employed",
                "value": "self-employed"
              },
              {
                "label": "Student",
                "value": "student"
              },
              {
                "label": "Retired",
                "value": "retired"
              },
              {
                "label": "Other",
                "value": "other"
              }
            ]
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "fieldId": "seeking-employment",
            "label": "Are you seeking employment?",
            "validations": {
              "required": {
                "error": "Select an option",
                "value": true
              }
            },
            "options": [
              {
                "label": "Yes",
                "value": "yes"
              },
              {
                "label": "No",
                "value": "no"
              }
            ],
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetFieldId": "employment-status",
                "operator": "in",
                "value": [
                  "unemployed",
                  "student"
                ]
              }
            ]
          }
        },
        {
          "ref": "components/generic-textarea",
          "overrides": {
            "fieldId": "job-interests-skills",
            "label": "Job interests and skills",
            "validations": {
              "required": {
                "value": true
              }
            },
            "ui": {
              "width": "long"
            },
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetStepId": "request-details",
                "targetFieldId": "seeking-employment",
                "operator": "equal",
                "value": "yes"
              }
            ]
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "transportation-details",
      "title": "Transportation details",
      "elements": [
        {
          "ref": "components/generic-date",
          "overrides": {
            "fieldId": "appointment-date",
            "label": "Appointment date",
            "validations": {
              "required": {
                "error": "Enter your appointment date",
                "value": true
              },
              "futureOrToday": {
                "error": "Appointment date cannot be in the past",
                "value": true
              }
            },
            "hint": "When is your appointment date (for example, 09 08 2022)"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "pickup-time",
            "label": "Pickup time",
            "validations": {
              "required": {
                "error": "Enter your pickup time",
                "value": true
              }
            },
            "hint": "When would you like to be collected (for example, 09:00)",
            "ui": {
              "width": "short"
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "destination",
            "label": "Destination",
            "validations": {
              "required": {
                "error": "Enter your destination",
                "value": true
              }
            },
            "hint": "When would you like to be transported to (for example, Queen Elizabeth Hospital)"
          }
        }
      ],
      "behaviours": [
        {
          "type": "stepConditionalOn",
          "targetStepId": "request-details",
          "targetFieldId": "nature-of-request",
          "operator": "in",
          "value": [
            "transportation",
            "both"
          ]
        }
      ]
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "description": "Review all the information you have provided before submitting your application.",
      "elements": [],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "fieldId": "declaration-confirmed",
            "label": "Declaration",
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            },
            "options": [
              {
                "label": "I declare that the information provided in this form is true and correct to the best of my knowledge.",
                "value": "confirmed"
              }
            ]
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application submitted",
      "elements": [],
      "behaviours": [],
      "nextSteps": [
        {
          "title": "What happens next",
          "content": "We have received your request for assistance and/or transportation. You will receive a confirmation email at the email address you provided. Our team at the Social Empowerment Agency will review your application and contact you within 5 working days to discuss your needs and next steps."
        }
      ]
    }
  ],
