          "ref": "components/upload-document",
          "overrides": {
            "hint": "Upload if she is or has been married.",
            "label": "Marriage certificate(s)",
            "fieldId": "marriage-certificate",
            "multiple": true,
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "value": "female",
                "operator": "equal",
                "targetFieldId": "centenarian-sex"
              }
            ]
          }
        }
      ],
      "description": "Upload a scan or clear photo. Accepted formats: PDF, JPG, PNG. Max 5MB per file."
