      "stepId": "declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "label": "Declaration",
            "fieldId": "declaration-confirmed",
            "options": [
              {
                "label": "I confirm that the information I have given is correct to the best of my knowledge, that the request will be received at least 3 months before the birthday, and that the documents I have uploaded are true copies of the originals.",
