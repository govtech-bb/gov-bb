              "required": {
                "value": true,
                "error": "Describe the handwashing arrangements"
              }
            }
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "label": "Waste disposal",
            "fieldId": "waste-disposal",
            "hint": "How will food waste and rubbish be stored and removed?",
            "validations": {
              "required": {
                "value": true,
                "error": "Describe how waste will be disposed of"
              }
            }
          }
        }
      ]
    },
    {
      "stepId": "documents",
      "title": "Supporting documents",
      "description": "You must upload a medical certificate for everyone handling food. All staff must also carry their certificate during the event.",
      "elements": [
        {
          "ref": "components/upload-document",
          "overrides": {
            "label": "Staff medical certificates",
            "fieldId": "medical-certs",
            "hint": "A valid medical certificate for you and everyone handling food. PDF, JPG or PNG.",
            "multiple": true,
            "validations": {
              "required": {
                "value": true,
                "error": "Upload a medical certificate for everyone handling food"
              },
              "fileTypes": {
                "value": ["application/pdf", "image/jpeg", "image/png"],
                "error": "Upload a PDF, JPG or PNG"
              },
              "itemMaxSize": {
                "value": 5242880,
                "error": "Each file must be 5 MB or smaller"
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "label": "List of vendors",
            "fieldId": "vendor-list",
            "hint": "A list of the food vendors taking part in your event. PDF, JPG, PNG, DOC or DOCX.",
            "behaviours": [
              {
                "type": "fieldConditionalOn",
                "targetStepId": "event-organiser",
                "targetFieldId": "is-organiser",
                "operator": "equal",
                "value": "yes"
              }
            ],
            "validations": {
              "required": {
                "value": true,
                "error": "Upload a list of the food vendors taking part in your event"
              },
              "fileTypes": {
                "value": [
                  "application/pdf",
                  "image/jpeg",
                  "image/png",
                  "application/msword",
                  "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                ],
                "error": "Upload a PDF, JPG, PNG, DOC or DOCX"
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "label": "Site or stall plan",
            "fieldId": "site-plan",
            "hint": "A plan of the event site, showing stall positions, waste disposal, water supply and facilities. PDF, JPG or PNG.",
            "behaviours": [
              {
                "type": "optionalIf",
                "targetStepId": "event-organiser",
                "targetFieldId": "is-organiser",
                "operator": "equal",
                "value": "no"
              }
            ],
            "validations": {
              "required": {
                "value": true,
                "error": "Upload a site or stall plan"
              },
              "fileTypes": {
                "value": ["application/pdf", "image/jpeg", "image/png"],
                "error": "Upload a PDF, JPG or PNG"
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "label": "Food business licence (optional)",
            "fieldId": "food-licence",
            "hint": "A copy of your valid food business licence, if you have one. PDF, JPG or PNG.",
            "validations": {
              "fileTypes": {
                "value": ["application/pdf", "image/jpeg", "image/png"],
                "error": "Upload a PDF, JPG or PNG"
              }
            }
          }
        }
      ]
