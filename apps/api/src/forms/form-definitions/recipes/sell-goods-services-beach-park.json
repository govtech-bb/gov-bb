        {
          "ref": "components/generic-text",
          "overrides": {
            "fieldId": "goods-description",
            "label": "Describe the goods you would like to sell",
            "hint": "For example, fresh, locally-sourced fruit",
            "validations": {
              "required": {
                "error": "Description of goods is required",
                "value": true
