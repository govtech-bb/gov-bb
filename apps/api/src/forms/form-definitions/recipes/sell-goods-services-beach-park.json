{
  "formId": "sell-goods-services-beach-park",
  "title": "Apply to sell goods or services at a beach or park",
  "description": "Apply for permission to sell goods or offer services at a public beach or park in Barbados.",
  "processors": [
    {
      "type": "email",
      "config": {
        "recipientField": "applicant-details.applicant-email",
        "subject": "Your beach/park vendor application has been received"
      }
