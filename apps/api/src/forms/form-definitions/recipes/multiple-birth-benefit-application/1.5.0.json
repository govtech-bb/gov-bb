{
  "formId": "multiple-birth-benefit-application",
  "title": "Multiple Birth Benefit Application",
  "description": "Application form for the Multiple Birth Benefit programme administered by the Social Empowerment Agency (SEA)",
  "version": "1.5.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Multiple Birth Benefit application received",
        "recipientField": "applicant-contact.email"
      }
    }
  ],
  "steps": [
    {
      "stepId": "applicant-information",
      "title": "Tell us about yourself",
      "elements": [
        {
          "ref": "components/title"
        },
        {
          "ref": "components/first-name"
        },
        {
          "ref": "components/middle-name"
        },
        {
          "ref": "components/last-name"
        },
        {
          "ref": "components/date-of-birth"
        },
        {
          "ref": "components/sex"
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "hint": "Enter your valid National ID Number (for example, 450702-0130)"
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "applicant-contact",
      "title": "Give your contact details",
      "elements": [
        {
          "ref": "components/address",
          "overrides": {
            "label": "Address line 1",
            "fieldId": "address-line-1"
          }
        },
        {
          "ref": "components/address",
          "overrides": {
            "hint": "Optional",
            "label": "Address line 2",
            "fieldId": "address-line-2",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/parish"
        },
        {
          "ref": "components/postcode",
          "overrides": {
            "hint": "Optional"
          }
        },
        {
          "ref": "components/email",
          "overrides": {
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/telephone"
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "children-overview",
      "title": "Tell us about your children",
      "elements": [
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Your relationship to the children",
            "fieldId": "relationship-to-children",
            "options": [
              {
                "label": "Mother",
                "value": "mother"
              },
              {
                "label": "Father",
                "value": "father"
              },
              {
                "label": "Guardian",
                "value": "guardian"
              }
            ],
            "validations": {
              "required": {
                "error": "Select your relationship to the children",
                "value": true
              }
            }
          }
        },
        {
          "ref": "components/generic-radio",
          "overrides": {
            "label": "Number of children born in the same birth",
            "fieldId": "number-of-children-born",
            "options": [
              {
                "label": "Twins",
                "value": "twins"
              },
              {
                "label": "Triplets",
                "value": "triplets"
              }
            ],
            "validations": {
              "required": {
                "error": "Select the number of children born",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "child-details",
      "title": "Give us your child's details",
      "elements": [
        {
          "ref": "components/first-name",
          "overrides": {
            "label": "Child's first name",
            "fieldId": "child-first-name"
          }
        },
        {
          "ref": "components/middle-name",
          "overrides": {
            "label": "Child's middle name",
            "fieldId": "child-middle-name"
          }
        },
        {
          "ref": "components/last-name",
          "overrides": {
            "label": "Child's last name",
            "fieldId": "child-last-name"
          }
        },
        {
          "ref": "components/date-of-birth",
          "overrides": {
            "fieldId": "child-date-of-birth"
          }
        },
        {
          "ref": "components/sex",
          "overrides": {
            "label": "Child's sex",
            "fieldId": "child-sex"
          }
        },
        {
          "ref": "components/national-id-number",
          "overrides": {
            "label": "Child's National ID Number",
            "fieldId": "child-national-id"
          }
        },
        {
          "ref": "components/generic-text",
          "overrides": {
            "hint": "Optional",
            "label": "Nursery or school attending",
            "fieldId": "child-school",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        }
      ],
      "behaviours": [
        {
          "max": 5,
          "min": 2,
          "type": "repeatable",
          "addAnotherLabel": "Do you need to add another child?"
        }
      ]
    },
    {
      "stepId": "banking-information",
      "title": "Give us your bank or credit union details",
      "elements": [
        {
          "ref": "components/bank"
        },
        {
          "ref": "components/address",
          "overrides": {
            "label": "Bank address line 1",
            "fieldId": "bank-address-line-1",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/parish",
          "overrides": {
            "label": "Bank parish",
            "fieldId": "bank-parish",
            "validations": {
              "required": {
                "value": false
              }
            }
          }
        },
        {
          "ref": "components/account-number"
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "supporting-documents",
      "title": "Give us your supporting documents",
      "description": "All documents must be certified copies. Uncertified copies will not be accepted.",
      "elements": [
        {
          "ref": "components/upload-document",
          "overrides": {
            "hint": "Please attach a certified copy",
            "label": "Your National Registration Card",
            "fieldId": "parent-nrc",
            "validations": {
              "required": {
                "error": "Upload your National Registration Card",
                "value": true
              },
              "fileTypes": {
                "error": "File must be a PDF or image (JPG, PNG)",
                "value": [
                  "application/pdf",
                  "image/jpeg",
                  "image/png"
                ]
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "hint": "Please attach certified copies",
            "label": "Birth certificate for each child",
            "fieldId": "child-birth-certificates",
            "multiple": true,
            "validations": {
              "required": {
                "error": "Upload birth certificates for each child",
                "value": true
              },
              "fileTypes": {
                "error": "File must be a PDF or image (JPG, PNG)",
                "value": [
                  "application/pdf",
                  "image/jpeg",
                  "image/png"
                ]
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "hint": "Please attach certified copies",
            "label": "National Registration Card for each child",
            "fieldId": "child-national-cards",
            "multiple": true,
            "validations": {
              "required": {
                "error": "Upload National Registration Cards for each child",
                "value": true
              },
              "fileTypes": {
                "error": "File must be a PDF or image (JPG, PNG)",
                "value": [
                  "application/pdf",
                  "image/jpeg",
                  "image/png"
                ]
              }
            }
          }
        },
        {
          "ref": "components/upload-document",
          "overrides": {
            "hint": "Upload documents verifying the bank name, branch and account number. Please attach certified copies",
            "label": "Banking details verification",
            "fieldId": "banking-details-verification",
            "validations": {
              "required": {
                "error": "Upload banking details verification",
                "value": true
              },
              "fileTypes": {
                "error": "File must be a PDF or image (JPG, PNG)",
                "value": [
                  "application/pdf",
                  "image/jpeg",
                  "image/png"
                ]
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "description": "Review all the information you have provided before submitting your application.",
      "elements": [],
      "behaviours": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
        {
          "ref": "components/confirmation",
          "overrides": {
            "label": "Declaration",
            "fieldId": "declaration-confirmed",
            "options": [
              {
                "label": "I declare that the information provided in this application is true and correct to the best of my knowledge. I understand that providing false or misleading information may result in disqualification from the benefit and possible legal action. Any changes in the children's circumstances should be immediately reported.",
                "value": "confirmed"
              }
            ],
            "validations": {
              "required": {
                "error": "You must confirm the declaration to continue",
                "value": true
              }
            }
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "submission-confirmation",
      "title": "Application submitted",
      "elements": [],
      "behaviours": []
    }
  ],
  "createdAt": "2026-06-17T10:50:41.039Z",
  "updatedAt": "2026-06-17T10:50:41.039Z"
}
