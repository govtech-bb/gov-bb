{
  "formId": "apply-for-national-summer-camp-programme-tropical-trails-and-tales-science-camp-2026",
  "title": "Apply for National Science Camp 2026",
  "description": "Apply for Tropical Trails and Tales Science Camp 2026.",
  "version": "1.5.0",
  "processors": [
    {
      "type": "email",
      "config": {
        "subject": "Your National Summer Camp Programme application has been received",
        "recipientField": "contact-details.parent-email"
      }
    },
    {
      "type": "webhook",
      "config": {
        "endpoint": {
          "env": "WEBHOOK_URL"
        },
        "auth": {
          "scheme": "apiKey",
          "header": "X-API-Key",
          "secretEnv": "WEBHOOK_SECRET"
        },
        "mapping": {
          "programmeCode": "SCIENCE2026",
          "applicant": {
            "name": [
              "child-details.child-first-name",
              "child-details.child-last-name"
            ],
            "email": "contact-details.parent-email",
            "phone": "contact-details.parent-mobile-phone"
          },
          "excludeSteps": [
            "check-your-answers",
            "declaration",
            "submission-confirmation"
          ]
        }
      }
    }
  ],
