{
  "formId": "cape-exam-registration-2024",
  "title": "Registration of Private Candidates for May/June CAPE Examination",
  "version": "1.1.0",
  "steps": [
    {
      "stepId": "student-information",
      "title": "Student Information",
      "elements": [
