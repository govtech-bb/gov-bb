        },
        {
          "ref": "components/generic/text-input",
          "overrides": {
            "type": "email",
            "label": "Email",
            "fieldId": "email",
            "required": true
          }
        },
        {
          "ref": "components/generic/text-input",
          "overrides": {
            "label": "Telephone No",
            "fieldId": "telephoneNo",
            "required": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "subject-registration",
      "title": "Subject Registration",
      "elements": [
        {
          "ref": "components/generic/show-hide",
          "overrides": {
            "label": "Subject Registration Information",
            "content": "Please list below the subject(s) for which you are registering. If you are repeating a subject from a previous sitting for which a School Based Assessment (SBA) was required, please select RESIT and type your previous registration number in the relevant field.",
            "fieldId": "subjectInfo"
          }
        },
        {
          "ref": "components/generic/table",
          "overrides": {
            "label": "Subjects for Registration",
            "columns": [
              {
                "type": "text",
                "label": "SUBJECT(S)",
                "fieldId": "subject"
              },
              {
                "type": "text",
                "label": "UNIT",
                "fieldId": "unit"
              },
              {
                "type": "text",
                "label": "ALTERNATIVE",
                "fieldId": "alternative"
              },
              {
                "type": "checkbox",
                "label": "RESIT",
                "fieldId": "resit"
              },
              {
                "type": "text",
                "label": "PREVIOUS REGISTRATION NUMBER",
                "fieldId": "previousRegistrationNumber",
                "conditionalOn": "resit"
              }
            ],
            "fieldId": "subjectsTable",
            "minRows": 6,
            "required": true
          }
        }
      ],
      "behaviours": []
    },
    {
      "stepId": "declarations",
      "title": "Important Information & Declarations",
      "elements": [
        {
          "ref": "components/generic/show-hide",
          "overrides": {
            "label": "Name Change Notice",
            "content": "Candidates should inform the CXC Local Registrar of any name changes which have occurred since their last examination sitting.",
            "fieldId": "nameChangeWarning"
          }
        },
        {
          "ref": "components/generic/show-hide",
          "overrides": {
            "label": "Timetable Check",
            "content": "Candidates should check ALL Timetables before registering so as to avoid any subject clashes with other Examination Boards.",
            "fieldId": "timetableWarning"
          }
        },
        {
          "ref": "components/generic/show-hide",
          "overrides": {
            "label": "Clash Policy",
            "content": "ABSOLUTELY NO ALTERNATIVE ARRANGEMENTS WILL BE MADE IN RESPECT OF CLASHES",
            "fieldId": "clashWarning",
            "styling": "warning"
          }
        }
      ],
      "behaviours": []
    },
