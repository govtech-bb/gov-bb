# NestJS API
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modular_forms
DB_SYNCHRONIZE=false
DB_LOGGING=false
# Set to "true" when the dump-recipes script targets a TLS-only Postgres
# (e.g. RDS). node-postgres connects in plaintext unless this is set, so a
# TLS-only server rejects it with `no pg_hba.conf entry ... no encryption`.
# Leave unset for local dev.
DATABASE_SSL=false

# SES email (optional — required only when forms use the email processor or the
# public site feedback form sends mail). Region falls back to AWS_DEFAULT_REGION.
# SES_REGION=us-east-1
# SES_FROM_ADDRESS=noreply@gov.bb          # must be a verified SES identity
# SES_CONFIGURATION_SET=                   # optional, for bounce/complaint tracking
# SES_DEFAULT_RECIPIENT=testing@govtech.bb # fallback for the form_config "config.*" kind
# Recipient for the public site feedback form (apps/landing /feedback). Set
# explicitly per environment — never routed through form_config, so it cannot
# silently fall back to the test inbox the way a missing form_config row does (#1139).
# FEEDBACK_RECIPIENT=feedback@govtech.bb

# EzPay (required when forms use the payment processor)
EZPAY_BASE_URL=https://test.ezpay.gov.bb
# JSON map of department → API key, e.g. {"civil-registry":"key-1","education":"key-2"}
EZPAY_DEPARTMENT_API_KEYS={}
# Webhook signature verification — defaults to "true" in env validation.
# To run locally without a secret, set both to the values below.
EZPAY_WEBHOOK_VERIFY_SIGNATURE=false
EZPAY_WEBHOOK_SECRET=

# Recipe source: "files" (default), "db", or "both".
# In "files" mode FormDefinitionsService reads recipes from JSON on disk at
# apps/api/src/forms/form-definitions/recipes/{formId}/{version}.json
# (resolved relative to the compiled module in prod). Recipe file edits in
# dev require a server restart — there is no hot reload.
# "db" reads only from `form_definitions` rows.
# "both" unions files and `form_definitions` rows (DB wins on collision) so
# Save-draft from /builder/ui is reachable via GET /form-definitions/* with
# no PR or restart.
# "db" and "both" are dev iteration escape hatches and are only honored when
# NODE_ENV=development. Outside development they are ignored (a warning is
# logged) and the API falls back to "files".
RECIPE_SOURCE=files

# Per-request DB recipe preview secret. Empty/unset disables the feature
# (fail closed). When set, a request carrying header X-Recipe-Preview equal to
# this value resolves its recipe from the DB ("both" logic) in any environment.
# Rotate by changing this env var in the deployment — old preview links stop
# working immediately.
# RECIPE_PREVIEW_TOKEN=
#
# IMPORTANT (#1646 Phase 3): for one shared `?preview=` link to unlock both the
# landing content page and the form end-to-end, RECIPE_PREVIEW_TOKEN must be set
# to the SAME value as landing's PREVIEW_SECRET in each environment.

# Parent domain for the cross-app shared `preview` cookie (#1646 Phase 3). When
# the API receives a valid X-Recipe-Preview header it mints an httpOnly cookie
# (named `preview`, byte-identical to landing's) scoped to this domain so
# landing, forms and the API — all subdomain siblings — share one visibility
# grant. Set per environment, e.g. .sandbox.alpha.gov.bb / .alpha.gov.bb. Leave
# unset locally / on Amplify previews → host-only cookie, no cross-app sharing.
# PREVIEW_COOKIE_DOMAIN=

# Smoke-submission secret. Empty/unset disables the feature (fail closed). When
# set, a POST /submissions carrying header X-Smoke-Submission equal to this
# value persists and validates normally but DROPS all processors (no real
# emails/webhooks/payment gating) — used by the live smoke matrix so a green run
# sends nothing real. Must match the SMOKE_SUBMISSION_TOKEN GitHub Actions secret
# for the smokes to go quiet (#1252).
# SMOKE_SUBMISSION_TOKEN=

# S3 file uploads
S3_BUCKET=modular-forms-uploads-sandbox
S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:4566   # uncomment for LocalStack
# S3_FORCE_PATH_STYLE=true            # uncomment for LocalStack
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_PRESIGN_TTL_SECONDS=900
UPLOAD_READ_URL_TTL_SECONDS=604800

# Outbound case-management webhook (youth-opportunity submissions).
# When a youth-opportunity form is submitted, the backend POSTs the application
# to ${WEBHOOK_URL}/api/webhooks/form-submitted with WEBHOOK_SECRET as the
# X-API-Key header. Leave WEBHOOK_URL empty to disable dispatch (logged and
# skipped) — useful for local dev. WEBHOOK_SECRET must match the key the
# case-management receiver expects.
WEBHOOK_URL=
WEBHOOK_SECRET=
# Outbound request timeout in ms (defaults to 10000 if unset).
WEBHOOK_TIMEOUT_MS=10000
