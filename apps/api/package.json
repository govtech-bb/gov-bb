{
  "name": "@govtech-bb/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nx start api",
    "start:dev": "nx dev api",
    "start:debug": "NODE_OPTIONS='--inspect' nx dev api",
    "build": "nx build api",
    "test": "vitest run",
    "migration:generate": "NODE_OPTIONS='--require tsconfig-paths/register' typeorm-ts-node-commonjs migration:generate -d typeorm.config.ts",
    "migration:run": "NODE_OPTIONS='--require tsconfig-paths/register' typeorm-ts-node-commonjs migration:run -d typeorm.config.ts",
    "migration:revert": "NODE_OPTIONS='--require tsconfig-paths/register' typeorm-ts-node-commonjs migration:revert -d typeorm.config.ts",
    "migration:show": "NODE_OPTIONS='--require tsconfig-paths/register' typeorm-ts-node-commonjs migration:show -d typeorm.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/client-sesv2": "^3.1041.0",
    "@aws-sdk/client-sqs": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@govtech-bb/database": "workspace:*",
    "@govtech-bb/expressions": "workspace:*",
    "@govtech-bb/form-conditions": "workspace:*",
    "@govtech-bb/form-types": "workspace:*",
    "@govtech-bb/form-validation": "workspace:*",
    "@govtech-bb/registry": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@smithy/core": "^3.24.3",
    "axios": "^1.15.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.21.0",
    "typeorm": "^0.3.28",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "supertest": "^7.2.2",
    "tsconfig-paths": "^4.2.0"
  },
  "lint-staged": {
    "*.{json,ts}": "npx prettier --write"
  }
}
