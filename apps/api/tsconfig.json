{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "module": "commonjs",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "types": ["node", "vitest/globals"],
    "preserveWatchOutput": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@govtech-bb/analytics": ["../../packages/analytics/src/index.ts"],
      "@govtech-bb/form-builder": ["../../packages/form-builder/src/index.ts"],
      "@govtech-bb/form-types": ["../../packages/form-types/src/index.ts"],
      "@govtech-bb/expressions": ["../../packages/expressions/src/index.ts"],
      "@govtech-bb/form-conditions": [
        "../../packages/form-conditions/src/index.ts"
      ],
      "@govtech-bb/form-validation": [
        "../../packages/form-validation/src/index.ts"
      ],
      "@govtech-bb/registry": ["../../packages/registry/src/index.ts"],
      "@govtech-bb/database": ["../../packages/database/src/index.ts"],
      "@govtech-bb/git-publish": ["../../packages/git-publish/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../../packages/database"
    },
    {
      "path": "../../packages/form-types"
    },
    {
      "path": "../../packages/form-validation"
    },
    {
      "path": "../../packages/form-conditions"
    },
    {
      "path": "../../packages/registry"
    }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
