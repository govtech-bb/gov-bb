{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "apps/api/dist",
        "tsConfig": "apps/api/tsconfig.json",
        "main": "apps/api/src/main.ts",
        "assets": [
          {
            "input": "apps/api/src/forms/form-definitions/recipes",
            "glob": "**/*.json",
            "output": "src/forms/form-definitions/recipes"
          },
          {
            "input": "apps/api/src/email/templates",
            "glob": "**/*.hbs",
            "output": "src/email/templates"
          }
        ],
        "rootDir": "apps/api"
      },
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build"
      }
    },
    "start": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build",
        "watch": false
      },
      "dependsOn": ["build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm test",
        "cwd": "apps/api"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/api/**/*.ts"]
      }
    }
  },
  "tags": []
}
