PORT=4200
VITE_API_URL=http://localhost:3001
DEVELOPMENT=true;
SKIP_CONTINUE_VALIDATION=true
# Comma-separated allowlist of hosts permitted in payment-redirect URLs.
# Matches the host exactly or as a subdomain (e.g. test.ezpay.gov.bb matches ezpay.gov.bb).
# Defaults to ezpay.gov.bb when unset.
VITE_PAYMENT_ALLOWED_ORIGINS=ezpay.gov.bb,test.ezpay.gov.bb

# Umami analytics (Umami Cloud).
#
# When VITE_UMAMI_WEBSITE_ID is set, the forms app injects the Umami
# script at runtime and tracks pageviews on TanStack Router resolution
# plus curated form-funnel events (form-open, form-step-view,
# form-step-advance/back, form-field-error, form-submit lifecycle,
# form-file-select). Field values, labels, and filenames are never sent.
#
# When VITE_UMAMI_WEBSITE_ID is unset, no script is injected and no
# requests are made to cloud.umami.is. Leave unset locally to keep dev
# traffic out of the analytics dataset.
VITE_UMAMI_WEBSITE_ID=

# Override the Umami script URL (defaults to https://cloud.umami.is/script.js).
# Only needed if self-hosting Umami or pointing at a different cloud region.
# VITE_UMAMI_SRC=
