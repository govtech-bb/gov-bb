{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowJs": true,
    "esModuleInterop": true,
    "types": ["jest", "node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/test/*.js"]
}
