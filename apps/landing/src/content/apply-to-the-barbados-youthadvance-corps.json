            {
              "mode": "normal",
              "text": "Young people between the ages of 16 and 20 years old are eligible to apply to the Barbados YouthADVANCE Corps (BYAC). BYAC is an initiative aimed at helping young people develop the skills they need to enter higher education, the workplace or for their own personal growth.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
