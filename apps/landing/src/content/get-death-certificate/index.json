            {
              "mode": "normal",
              "text": "This service can be used to get a copy of a death certificate for anyone whose death was registered in Barbados.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "Most copies of death certificates are requested soon after the death takes place and is registered.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "However, copies for a deceased Barbadian citizen can be requested at any point. They are essential for sorting out the deceased’s estate, and for insurance purposes.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "You can request a copy on someone else’s behalf but you must disclose:",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
