{
  "title": "Get a copy of a death certificate",
  "description": "Apply online to get a certified copy of a death certificate for anyone whose death was registered in Barbados. Certificates are issued by the Registration Department.",
  "categories": ["family-birth-relationships"],
  "start_type": "form",
  "form_id": "get-death-certificate",
  "stage": "alpha",
  "updated_at": "2026-05-29",
