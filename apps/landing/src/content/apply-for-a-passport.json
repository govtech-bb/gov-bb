{
  "title": "Apply for a passport",
  "description": "This article provides detailed instructions for citizens of Barbados on how to apply for a passport, including requirements, application forms, collection procedures, and fee schedules.",
  "categories": ["travel-id-citizenship"],
  "service_type": "information",
  "stage": "alpha",
  "source_url": "https://www.gov.bb/Citizens/apply-passport",
  "updated_at": "2026-05-28",
  "body": {
    "root": {
      "type": "root",
      "format": "",
      "indent": 0,
      "version": 1,
      "children": [
        {
          "tag": "h2",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "How to Apply for a Passport",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "If you are a citizen of Barbados, you may apply for a passport from the Immigration Department in Barbados, or at one of Barbados' diplomatic and consular missions abroad.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "To schedule an appointment online, ",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            },
            {
              "id": "6a183320bfdf3ba829d63216",
              "type": "link",
              "fields": {
                "url": "http://www.immigration.gov.bb/",
                "newTab": false,
                "linkType": "custom"
              },
              "format": "",
              "indent": 0,
              "version": 3,
              "children": [
                {
                  "mode": "normal",
                  "text": "click here",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "mode": "normal",
              "text": ".",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "If you are more than 16 years of age, you should complete an 'Application for a Barbados Passport' ",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            },
            {
              "id": "6a183320bfdf3ba829d63217",
              "type": "link",
              "fields": {
                "url": "http://www.immigration.gov.bb/documents/Form%20A.pdf",
                "newTab": false,
                "linkType": "custom"
              },
              "format": "",
              "indent": 0,
              "version": 3,
              "children": [
                {
                  "mode": "normal",
                  "text": "Form A",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 1,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "mode": "normal",
              "text": " in your own hand-writing.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "tag": "ul",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  Use Block Letters for all names except your signature.",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  Applications for children under the age of 16 should be made on ",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                },
                {
                  "id": "6a183320bfdf3ba829d63218",
                  "type": "link",
                  "fields": {
                    "url": "http://www.immigration.gov.bb/documents/Form%20B.pdf",
                    "newTab": false,
                    "linkType": "custom"
                  },
                  "format": "",
                  "indent": 0,
                  "version": 3,
                  "children": [
                    {
                      "mode": "normal",
                      "text": "Form B",
                      "type": "text",
                      "style": "",
                      "detail": 0,
                      "format": 1,
                      "version": 1
                    }
                  ],
                  "direction": null
                },
                {
                  "mode": "normal",
                  "text": ".",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 3,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  The application form should be accompanied by two (2) photographs.",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 4,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  The photographs should not be more than five (5) centimetres by five (5) centimetres and should be taken by a professional photographer",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 5,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  Please ensure that you ",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                },
                {
                  "id": "6a183320bfdf3ba829d63219",
                  "type": "link",
                  "fields": {
                    "url": "http://www.immigration.gov.bb/documents/signature.pdf#Signature",
                    "newTab": false,
                    "linkType": "custom"
                  },
                  "format": "",
                  "indent": 0,
                  "version": 3,
                  "children": [
                    {
                      "mode": "normal",
                      "text": "sign your name in the boxes provided",
                      "type": "text",
                      "style": "",
                      "detail": 0,
                      "format": 1,
                      "version": 1
                    }
                  ],
                  "direction": null
                },
                {
                  "mode": "normal",
                  "text": " at the bottom of page two of the application form as well as the Declaration at Section 11, page four.",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 6,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  The Form and one (1) photograph must also be certified by a person authorized to act as a guarantor. Specimens of passport ",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                },
                {
                  "id": "6a183320bfdf3ba829d6321a",
                  "type": "link",
                  "fields": {
                    "url": "http://www.immigration.gov.bb/documents/formA_Specimen.pdf",
                    "newTab": false,
                    "linkType": "custom"
                  },
                  "format": "",
                  "indent": 0,
                  "version": 3,
                  "children": [
                    {
                      "mode": "normal",
                      "text": "Form A",
                      "type": "text",
                      "style": "",
                      "detail": 0,
                      "format": 1,
                      "version": 1
                    }
                  ],
                  "direction": null
                },
                {
                  "mode": "normal",
                  "text": " and ",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                },
                {
                  "id": "6a183320bfdf3ba829d6321b",
                  "type": "link",
                  "fields": {
                    "url": "http://www.immigration.gov.bb/documents/formB_Specimen.pdf",
