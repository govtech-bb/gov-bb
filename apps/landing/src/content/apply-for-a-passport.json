        {
          "tag": "h2",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "The process for collection",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null
        },
        {
          "tag": "ul",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  Passports must be collected by the holder of the passport except in ",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                },
                {
                  "mode": "normal",
                  "text": "special circumstances",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 1,
                  "version": 1
                },
                {
                  "mode": "normal",
                  "text": ".",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  Persons collecting passports must produce their receipt and ID card or expired passport.",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            }
          ],
          "listType": "bullet",
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "If a passport is being collected by a person other than the Applicant (in ",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            },
            {
              "mode": "normal",
              "text": "special circumstances",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 1,
              "version": 1
            },
            {
              "mode": "normal",
              "text": "):",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "tag": "ul",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  a letter signed by the applicant giving authorization",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  a letter signed and stamped by a Notary Public / Justice of the Peace.",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 3,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  applicant's ID card",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 4,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "  Id card of person collecting document",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            }
          ],
          "listType": "bullet",
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "All applicants should submit their original birth certificate or proof of citizenship along with their application.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "If you do not have an original birth certificate, you may apply for one at the: Registration Office Supreme Court Complex White Park Road St. Michael Barbados.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "The fees for Passports are as follows. The fees for passports issued by our diplomatic missions overseas vary from mission to mission. You should, therefore, check with the respective mission regarding the fee schedule.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "New Passport Fees Effective December 01, 2010",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
