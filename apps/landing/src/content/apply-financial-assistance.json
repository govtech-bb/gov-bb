          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "How to apply for financial assitance",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null
        },
        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "Apply online or in person",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "You can apply for financial assistance either by:",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "tag": "ol",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "Going to the welfare office in the parish where you live and completing a paper form (the National Assistance application form). At the moment, the form does not ask for your contact number but you must include one so an officer can reach you and arrange an interview.",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            }
          ],
          "listType": "number",
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "Welfare offices   Weymouth Corporate Center Roebuck St. Bridgetown St. Michael",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
