{
  "title": "Apply for financial assistance",
  "description": "Apply for financial assistance from the Government of Barbados if you need help with food, clothing, utility bills, housing, assistive devices, or other essential needs.",
  "categories": ["money-financial-support"],
  "stage": "alpha",
  "publish_date": "2025-11-12",
  "body": {
    "root": {
      "type": "root",
      "format": "",
      "indent": 0,
      "version": 1,
      "children": [
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "If you live in Barbados and need financial help you can apply for financial assistance.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "If you need help with things like food, clothing, burials, assistive devices (for example, dentures, hearing aids and spectacles), as well as payment of utility bills and house rent, you can apply for assistance in-kind.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "A welfare officer will assess your needs under the National Assistance framework and make a recommendation to determine if you should be granted assistance.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "tag": "h2",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "Who can use this service  ",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "You can apply for assistance for a range of reasons, including if you:",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "tag": "ul",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "are unemployed or underemployed",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "are elderly",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 3,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "have a disability but are not receiving National Insurance and Social Security Service (NISS) benefits",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 4,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "have children or dependents who you are struggling to support",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 5,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "have finished school and are unemployed but have enrolled in a tertiary institution",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 6,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "are homeless",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            },
            {
              "type": "listitem",
              "value": 7,
              "format": "",
              "indent": 0,
              "version": 1,
              "children": [
                {
                  "mode": "normal",
                  "text": "are the victim of a disaster or an accident",
                  "type": "text",
                  "style": "",
                  "detail": 0,
                  "format": 0,
                  "version": 1
                }
              ],
              "direction": null
            }
          ],
          "listType": "bullet",
          "direction": null
        },
        {
