          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "Mission",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [
            {
              "mode": "normal",
              "text": "To contribute to the overall socio-economic development of Barbados and the empowerment of all members of society by fully utilizing all available human, financial and technological resources; formulating evidence-based policy; and implementing timely, effective and equitably accessible social programmes and services.",
              "type": "text",
              "style": "",
              "detail": 0,
              "format": 0,
              "version": 1
            }
          ],
          "direction": null,
          "textStyle": "",
          "textFormat": 0
        },
        {
          "tag": "h2",
