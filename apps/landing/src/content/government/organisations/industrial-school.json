{
  "kind": "department",
  "slug": "industrial-school",
  "name": "Government Industrial School",
  "stage": "alpha",
  "shortDescription": "A secure residential facility for court-ordered child placements, focused on providing a safe, caring environment that supports rehabilitation and family reintegration.",
  "intro": "The facility aims to accommodate children ordered to be resident therein in a safe, secure, and caring environment, while addressing rehabilitation needs and supporting family reintegration into the community.",
