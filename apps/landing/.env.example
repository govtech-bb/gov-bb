# Umami analytics (Umami Cloud).
#
# When VITE_UMAMI_WEBSITE_ID is set, the landing app injects the Umami script
# at SSR time and tracks pageviews on TanStack Router resolution plus curated
# click events tagged with data-umami-event in components and routes.
#
# When VITE_UMAMI_WEBSITE_ID is unset, no script is injected and no requests
# are made to cloud.umami.is. Leave unset locally to keep dev traffic out of
# the analytics dataset.
VITE_UMAMI_WEBSITE_ID=

# Override the Umami script URL (defaults to https://cloud.umami.is/script.js).
# Only needed if self-hosting Umami or pointing at a different cloud region.
# VITE_UMAMI_SRC=
