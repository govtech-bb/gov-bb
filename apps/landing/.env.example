# Umami analytics (Umami Cloud).
#
# When VITE_UMAMI_WEBSITE_ID is set, the landing app injects the Umami script
# at SSR time and tracks pageviews on TanStack Router resolution plus curated
# click events tagged with data-umami-event in components and routes.
#
# When VITE_UMAMI_WEBSITE_ID is unset, no script is injected and no requests
# are made to cloud.umami.is. Leave unset locally to keep dev traffic out of
# the analytics dataset.
VITE_UMAMI_WEBSITE_ID=

# Override the Umami script URL (defaults to https://cloud.umami.is/script.js).
# Only needed if self-hosting Umami or pointing at a different cloud region.
# VITE_UMAMI_SRC=

# Base URL of the deployed forms app. Used by the Markdown anchor renderer
# to build Start now button hrefs:
#   ${VITE_FORMS_URL}/forms/<form_id>
# `form_id` is declared in the page's frontmatter. Defaults to
# https://forms.sandbox.alpha.gov.bb in code if unset; set per environment.
# VITE_FORMS_URL=https://forms.alpha.gov.bb

# Base URL of the forms API. Read at build time only — the pre-build script
# `apps/landing/scripts/fetch-form-manifest.mjs` hits
# ${VITE_FORMS_API_URL}/form-definitions to generate
# src/content/available-forms.gen.ts. If the API is unreachable the build
# fails. Defaults to https://forms.api.sandbox.alpha.gov.bb if unset.
# VITE_FORMS_API_URL=https://forms.api.alpha.gov.bb

# Base URL of the deployed chat app. Used by ChatAssistant to probe
# /api/health/public for the live Online badge and to hand off submitted
# queries via ?q=. Baked into the client bundle at build time. Defaults to
# https://chat.sandbox.alpha.gov.bb in code when unset, so leaving this
# unset still produces a working deployed build. Set explicitly to
# override (e.g. local dev against a chat instance on localhost).
#   Local: http://localhost:3001
# VITE_CHAT_URL=

# Origin of the Payload CMS, used by the /preview route's Live Preview hook to
# validate incoming postMessage events. Defaults to http://localhost:8000.
# VITE_CMS_URL=http://localhost:8000

# Feature-flag reviewer token. Server-only (no VITE_ prefix). A reviewer visits
# any URL with `?flag=<FLAG_SECRET>` and the server sets an httpOnly cookie so
# subsequent navigations include `flag: 'flagged'` content in CMS queries.
# `?flag=exit` clears the cookie. Leaving this unset disables the gate
# entirely — no token can ever match, so no reviewer can unlock flagged docs.
# FLAG_SECRET=
