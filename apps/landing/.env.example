# Preview token for the content rollout gate.
#
# Pages with `visibility: preview` in their frontmatter are hidden from the
# public (they 404, are dropped from listings and search, and carry noindex).
# A reviewer unlocks them by visiting any URL with ?preview=<PREVIEW_SECRET>;
# the server validates the token and sets an httpOnly cookie. ?preview=exit
# clears it. This is a SERVER-ONLY secret — it has no VITE_ prefix, so it is
# never shipped to the client bundle. When unset, no token will match, so
# preview content stays hidden from everyone.
PREVIEW_SECRET=

# Umami analytics (Umami Cloud).
#
# When VITE_UMAMI_WEBSITE_ID is set, the landing app injects the Umami script
# at SSR time and tracks pageviews on TanStack Router resolution plus curated
# click events tagged with data-umami-event in components and routes.
#
# When VITE_UMAMI_WEBSITE_ID is unset, no script is injected and no requests
# are made to cloud.umami.is. Leave unset locally to keep dev traffic out of
# the analytics dataset.
VITE_UMAMI_WEBSITE_ID=

# Override the Umami script URL (defaults to https://cloud.umami.is/script.js).
# Only needed if self-hosting Umami or pointing at a different cloud region.
# VITE_UMAMI_SRC=

# Base URL of the deployed forms app. Used by the Markdown anchor renderer
# to build Start now button hrefs:
#   ${VITE_FORMS_URL}/forms/<form_id>
# `form_id` is declared in the page's frontmatter. REQUIRED in production — an
# unset value fails the build/boot fast (#1366). Defaults to
# https://forms.sandbox.alpha.gov.bb only in dev (import.meta.env.DEV).
# VITE_FORMS_URL=https://forms.alpha.gov.bb

# Base URL of the forms API. Used server-side in two places:
#   1. `available-forms.ts` fetches ${VITE_FORMS_API_URL}/form-definitions to
#      decide which Start now buttons to render (60s cache, last-known-good).
#   2. `send-feedback.ts` POSTs the /feedback form to ${VITE_FORMS_API_URL}/feedback,
#      which emails it to the team.
# Because the Amplify SSR Lambda never sees Console env vars at runtime, this is
# snapshotted into the Nitro runtimeConfig at build time (see vite.config.ts) and
# read via useRuntimeConfig(). Changing it therefore needs a redeploy.
# REQUIRED in production — an unset value fails fast (#1366); defaults to
# https://forms.api.sandbox.alpha.gov.bb only in dev.
# VITE_FORMS_API_URL=https://forms.api.alpha.gov.bb

# Base URL of the deployed chat app. Used by ChatAssistant to probe
# /api/health/public for the live Online badge and to hand off submitted
# queries via ?q=. Baked into the client bundle at build time. REQUIRED in
# production — an unset value fails fast (#1366); defaults to
# https://chat.sandbox.alpha.gov.bb only in dev. Set explicitly to override
# (e.g. local dev against a chat instance on localhost).
#   Local: http://localhost:3001
# VITE_CHAT_URL=

# Origin of the form_builder app allowed to drive the /preview-start-page
# live-preview route over postMessage (the content CMS embeds that route in an
# iframe). Baked into the client bundle at build time. In dev any origin is
# accepted; in production it now FAILS CLOSED (#1366) — an unset value accepts
# NO origin, so the live preview only works once this is set to the
# form_builder origin for the environment.
#   e.g. https://builder.sandbox.alpha.gov.bb
# VITE_START_PAGE_EDITOR_ORIGIN=
