{
  "permissions": {
    "allow": [
      "Bash(gh issue *)",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "Bash(gh label *)",
      "Bash(gh repo view *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git show *)",
      "Bash(git diff *)"
    ]
  },
  "worktree": {
    "baseRef": "head"
  },
  "enabledPlugins": {
    "bb@team-skills": true
  },
  "extraKnownMarketplaces": {
    "team-skills": {
      "source": {
        "source": "github",
        "repo": "govtech-bb/team-skills"
      },
      "autoUpdate": true
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dotted-branch.sh\"",
            "statusMessage": "Checking branch name"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-commit-plans.sh\"",
            "statusMessage": "Guarding docs/plans"
          }
        ]
      }
    ]
  }
}
