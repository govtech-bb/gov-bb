{
  "name": "form-builder",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/form-builder/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/form-builder/dist",
        "tsConfig": "packages/form-builder/tsconfig.json",
        "main": "packages/form-builder/src/index.ts",
        "rootDir": "packages/form-builder"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/form-builder"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/form-builder/**/*.ts"]
      }
    }
  },
  "tags": []
}
