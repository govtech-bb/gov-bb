{
  "name": "form-types",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "govtech-bb/form-types/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/govtech-bb/form-types",
        "tsConfig": "govtech-bb/form-types/tsconfig.json",
        "main": "govtech-bb/form-types/src/index.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "govtech-bb/form-types/**/*.ts"
        ]
      }
    }
  },
  "tags": []
}
