{
  "name": "git-publish",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/git-publish/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/git-publish",
        "tsConfig": "packages/git-publish/tsconfig.json",
        "main": "packages/git-publish/src/index.ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/git-publish"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/git-publish/**/*.ts"]
      }
    }
  },
  "tags": []
}
